generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id            String         @id @default(uuid())
  name          String         @unique
  displayName   String
  description   String?
  price         Decimal        @db.Decimal(12, 2)
  currency      String         @default("COP")
  isActive      Boolean        @default(true)
  isCustom      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  features      PlanFeature[]
  subscriptions Subscription[]

  @@map("plans")
}

model PlanFeature {
  id     String  @id @default(uuid())
  planId String
  key    String
  value  String
  label  String?
  plan   Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@map("plan_features")
}

model Company {
  id                 String            @id @default(uuid())
  name               String
  nit                String            @unique
  razonSocial        String
  email              String
  phone              String?
  address            String?
  city               String?
  department         String?
  cityCode           String?
  departmentCode     String?
  country            String            @default("CO")
  status             CompanyStatus     @default(ACTIVE)
  dianTestMode       Boolean           @default(true)
  dianSoftwareId     String?
  dianSoftwarePin    String?
  dianTestSetId      String?
  dianClaveTecnica   String?
  dianResolucion     String?
  dianPrefijo        String?
  dianRangoDesde     Int?
  dianRangoHasta     Int?
  dianFechaDesde     String?
  dianFechaHasta     String?
  dianCertificate    String?
  dianCertificateKey String?
  logoUrl            String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  auditLogs          AuditLog[]
  categories         Category[]
  customers          Customer[]
  employees          employees[]
  importJobs         ImportJob[]
  integrations       Integration[]
  invoices           Invoice[]
  payroll_records    payroll_records[]
  products           Product[]
  subscriptions      Subscription[]
  usageTracking      UsageTracking[]
  users              User[]

  @@index([status])
  @@index([nit])
  @@map("companies")
}

model Subscription {
  id           String             @id @default(uuid())
  companyId    String
  planId       String
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?
  trialEndsAt  DateTime?
  customLimits Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  company      Company            @relation(fields: [companyId], references: [id])
  plan         Plan               @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  isActive     Boolean     @default(true)
  isSuperAdmin Boolean     @default(false)
  companyId    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  lastLoginAt  DateTime?
  refreshToken String?
  auditLogs    AuditLog[]
  importJobs   ImportJob[]
  roles        UserRole[]
  company      Company?    @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  displayName String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model RolePermission {
  id       String @id @default(uuid())
  roleId   String
  resource String
  action   String
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Category {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  company     Company    @relation(fields: [companyId], references: [id])
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("categories")
}

model Product {
  id           String        @id @default(uuid())
  companyId    String
  categoryId   String?
  sku          String
  name         String
  description  String?
  price        Decimal       @db.Decimal(12, 2)
  cost         Decimal       @default(0) @db.Decimal(12, 2)
  stock        Int           @default(0)
  minStock     Int           @default(0)
  unit         String        @default("UND")
  taxRate      Decimal       @default(19) @db.Decimal(5, 2)
  taxType      TaxType       @default(IVA)
  status       ProductStatus @default(ACTIVE)
  imageUrl     String?
  barcode      String?
  unspscCode   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  invoiceItems InvoiceItem[]
  category     Category?     @relation(fields: [categoryId], references: [id])
  company      Company       @relation(fields: [companyId], references: [id])

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([companyId, status])
  @@map("products")
}

model Customer {
  id             String       @id @default(uuid())
  companyId      String
  documentType   DocumentType @default(NIT)
  documentNumber String
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  department     String?
  cityCode       String?
  departmentCode String?
  country        String       @default("CO")
  isActive       Boolean      @default(true)
  creditLimit    Decimal?     @db.Decimal(12, 2)
  creditDays     Int?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  company        Company      @relation(fields: [companyId], references: [id])
  invoices       Invoice[]

  @@unique([companyId, documentType, documentNumber])
  @@index([companyId])
  @@map("customers")
}

model Invoice {
  id             String        @id @default(uuid())
  companyId      String
  customerId     String
  invoiceNumber  String
  prefix         String        @default("FV")
  type           InvoiceType   @default(VENTA)
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime
  dueDate        DateTime?
  subtotal       Decimal       @db.Decimal(12, 2)
  taxAmount      Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  notes          String?
  dianCufe       String?       @unique
  dianQrCode     String?
  dianStatus     String?
  dianStatusCode String?
  dianStatusMsg  String?
  dianZipKey     String?
  dianAttempts   Int           @default(0)
  dianSentAt     DateTime?
  dianResponseAt DateTime?
  dianXmlBase64  String?
  xmlContent     String?
  xmlSigned      String?
  pdfUrl         String?
  xmlUrl         String?
  currency       String        @default("COP")
  exchangeRate   Decimal       @default(1) @db.Decimal(12, 4)
  paymentMethod  String        @default("cash")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  dianErrors     String?
  items          InvoiceItem[]
  company        Company       @relation(fields: [companyId], references: [id])
  customer       Customer      @relation(fields: [customerId], references: [id])

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@index([dianZipKey])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  taxAmount   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  total       Decimal  @db.Decimal(12, 2)
  unit        String?
  position    Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model Integration {
  id         String            @id @default(uuid())
  companyId  String
  type       IntegrationType
  name       String
  config     Json
  isActive   Boolean           @default(true)
  lastSyncAt DateTime?
  status     IntegrationStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  company    Company           @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("integrations")
}

model UsageTracking {
  id        String   @id @default(uuid())
  companyId String
  metric    String
  value     Int      @default(0)
  period    String
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, metric, period])
  @@index([companyId, period])
  @@map("usage_tracking")
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String?
  userId     String?
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  company    Company? @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

model ImportJob {
  id            String        @id @default(uuid())
  companyId     String
  userId        String
  type          String        @default("PRODUCTS")
  status        ImportStatus  @default(PENDING)
  fileName      String
  fileUrl       String
  totalRows     Int           @default(0)
  processedRows Int           @default(0)
  successRows   Int           @default(0)
  errorRows     Int           @default(0)
  reportUrl     String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  errors        ImportError[]
  company       Company       @relation(fields: [companyId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("import_jobs")
}

model ImportError {
  id          String    @id @default(uuid())
  importJobId String
  rowNumber   Int
  field       String?
  value       String?
  message     String
  rawData     Json?
  createdAt   DateTime  @default(now())
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@map("import_errors")
}

model employees {
  id              String   @id @default(uuid())
  companyId       String
  documentType    String            @default("CC")
  documentNumber  String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  position        String
  baseSalary      Decimal           @db.Decimal(12, 2)
  contractType    String            @default("INDEFINITE")
  hireDate        DateTime
  city            String?
  bankAccount     String?
  bankName        String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  companies       Company           @relation(fields: [companyId], references: [id])
  payroll_records payroll_records[]

  @@unique([companyId, documentNumber])
  @@index([companyId])
}

model payroll_records {
  id        String   @id @default(uuid())
  companyId          String
  employeeId         String
  period             String
  payDate            DateTime
  status             String    @default("DRAFT")
  cune               String?   @unique
  baseSalary         Decimal   @db.Decimal(12, 2)
  daysWorked         Int       @default(30)
  overtimeHours      Decimal   @default(0) @db.Decimal(8, 2)
  bonuses            Decimal   @default(0) @db.Decimal(12, 2)
  commissions        Decimal   @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal   @default(0) @db.Decimal(12, 2)
  vacationPay        Decimal   @default(0) @db.Decimal(12, 2)
  healthEmployee     Decimal   @default(0) @db.Decimal(12, 2)
  pensionEmployee    Decimal   @default(0) @db.Decimal(12, 2)
  sickLeave          Decimal   @default(0) @db.Decimal(12, 2)
  loans              Decimal   @default(0) @db.Decimal(12, 2)
  otherDeductions    Decimal   @default(0) @db.Decimal(12, 2)
  healthEmployer     Decimal   @default(0) @db.Decimal(12, 2)
  pensionEmployer    Decimal   @default(0) @db.Decimal(12, 2)
  arl                Decimal   @default(0) @db.Decimal(12, 2)
  compensationFund   Decimal   @default(0) @db.Decimal(12, 2)
  totalEarnings      Decimal   @db.Decimal(12, 2)
  totalDeductions    Decimal   @db.Decimal(12, 2)
  netPay             Decimal   @db.Decimal(12, 2)
  totalEmployerCost  Decimal   @db.Decimal(12, 2)
  notes              String?
  submittedAt        DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companies          Company   @relation(fields: [companyId], references: [id])
  employees          employees @relation(fields: [employeeId], references: [id])

  @@unique([companyId, employeeId, period])
  @@index([companyId])
  @@index([companyId, period])
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum TaxType {
  IVA
  INC
  ICA
  NONE
}

enum DocumentType {
  NIT
  CC
  CE
  PASSPORT
  TI
}

enum InvoiceType {
  VENTA
  NOTA_CREDITO
  NOTA_DEBITO
  SOPORTE_ADQUISICION
}

enum InvoiceStatus {
  DRAFT
  SENT_DIAN
  ACCEPTED_DIAN
  REJECTED_DIAN
  PAID
  CANCELLED
  OVERDUE
}

enum IntegrationType {
  DIAN
  NOMINA
  CONTABILIDAD
  BANCOS
  ECOMMERCE
  CUSTOM
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  ERROR
  SUSPENDED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
  CANCELLED
}
