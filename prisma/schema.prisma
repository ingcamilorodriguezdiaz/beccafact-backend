generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id            String         @id @default(uuid())
  name          String         @unique
  displayName   String
  description   String?
  price         Decimal        @db.Decimal(12, 2)
  currency      String         @default("COP")
  isActive      Boolean        @default(true)
  isCustom      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  features      PlanFeature[]
  subscriptions Subscription[]

  @@map("plans")
}

model PlanFeature {
  id     String  @id @default(uuid())
  planId String
  key    String
  value  String
  label  String?
  plan   Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@map("plan_features")
}

model Company {
  id                          String                       @id @default(uuid())
  name                        String
  nit                         String                       @unique
  razonSocial                 String
  email                       String
  phone                       String?
  address                     String?
  city                        String?
  department                  String?
  cityCode                    String?
  departmentCode              String?
  country                     String                       @default("CO")
  status                      CompanyStatus                @default(ACTIVE)
  dianTestMode                Boolean                      @default(true)
  dianSoftwareId              String?
  dianSoftwarePin             String?
  dianTestSetId               String?
  dianClaveTecnica            String?
  dianResolucion              String?
  dianPrefijo                 String?
  dianRangoDesde              Int?
  dianRangoHasta              Int?
  dianFechaDesde              String?
  dianFechaHasta              String?
  dianCertificate             String?
  dianCertificateKey          String?
  logoUrl                     String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  deletedAt                   DateTime?
  nominaSoftwareId            String?
  nominaSoftwarePin           String?
  nominaTestSetId             String?
  dianPosResolucion           String?
  dianPosPrefijo              String?
  dianPosRangoDesde           Int?
  dianPosRangoHasta           Int?
  dianPosFechaDesde           String?
  dianPosFechaHasta           String?
  accountPayablePayments      AccountPayablePayment[]
  accountPayableSchedules     AccountPayableSchedule[]
  accountingAccounts          AccountingAccount[]
  accountingPeriods           AccountingPeriod[]
  accountsPayable             AccountPayable[]
  auditLogs                   AuditLog[]
  branches                    Branch[]
  carteraAdjustments          CarteraAdjustment[]
  carteraBankMovements        CarteraBankMovement[]
  carteraCollectionFollowUps  CarteraCollectionFollowUp[]
  carteraPaymentPromises      CarteraPaymentPromise[]
  carteraPayments             CarteraPayment[]
  carteraReceiptApplications  CarteraReceiptApplication[]
  carteraReceipts             CarteraReceipt[]
  categories                  Category[]
  customers                   Customer[]
  dianTestSets                DianTestSet[]
  employees                   employees[]
  importJobs                  ImportJob[]
  integrations                Integration[]
  invoices                    Invoice[]
  journalEntries              JournalEntry[]
  payroll_records             payroll_records[]
  posCashMovements            PosCashMovement[]
  pos_sales                   PosSale[]
  pos_sessions                PosSession[]
  products                    Product[]
  purchaseAdjustments         PurchaseAdjustment[]
  purchaseAdvanceApplications PurchaseAdvanceApplication[]
  purchaseAdvances            PurchaseAdvance[]
  purchaseBudgets             PurchaseBudget[]
  purchaseFrameworkAgreements PurchaseFrameworkAgreement[]
  purchaseInventoryMovements  PurchaseInventoryMovement[]
  purchaseInvoices            PurchaseInvoice[]
  purchaseOrderReceipts       PurchaseOrderReceipt[]
  purchaseOrders              PurchaseOrder[]
  purchaseRequestApprovals    PurchaseRequestApproval[]
  purchaseRequests            PurchaseRequest[]
  purchaseSupplierQuotes      PurchaseSupplierQuote[]
  quote_approval_policies     QuoteApprovalPolicy[]
  quoteApprovalRequests       QuoteApprovalRequest[]
  quote_attachments           QuoteAttachment[]
  quote_comments              QuoteComment[]
  quoteFollowUps              QuoteFollowUp[]
  quote_lost_reasons          QuoteLostReason[]
  quote_price_lists           QuotePriceList[]
  quote_sales_owners          QuoteSalesOwner[]
  quote_source_channels       QuoteSourceChannel[]
  quote_stages                QuoteStage[]
  quote_templates             QuoteTemplate[]
  quoteVersions               QuoteVersion[]
  quotes                      Quote[]
  subscriptions               Subscription[]
  usageTracking               UsageTracking[]
  users                       User[]

  @@index([status])
  @@index([nit])
  @@map("companies")
}

model Branch {
  id              String            @id @default(uuid())
  companyId       String
  name            String
  address         String?
  city            String?
  department      String?
  phone           String?
  email           String?
  isMain          Boolean           @default(false)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  cityCode        String?
  country         String?           @default("CO")
  departmentCode  String?
  company         Company           @relation(fields: [companyId], references: [id])
  employees       employees[]       @relation("EmployeeBranch")
  invoices        Invoice[]
  payroll_records payroll_records[] @relation("PayrollBranch")
  posSales        PosSale[]
  posSessions     PosSession[]
  products        Product[]
  userBranches    UserBranch[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, isActive])
  @@map("branches")
}

model UserBranch {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  companyId String
  createdAt DateTime @default(now())
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([companyId])
  @@map("user_branches")
}

model Subscription {
  id           String             @id @default(uuid())
  companyId    String
  planId       String
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?
  trialEndsAt  DateTime?
  customLimits Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  company      Company            @relation(fields: [companyId], references: [id])
  plan         Plan               @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

model User {
  id                                 String                       @id @default(uuid())
  email                              String                       @unique
  password                           String
  firstName                          String
  lastName                           String
  phone                              String?
  avatar                             String?
  isActive                           Boolean                      @default(true)
  isSuperAdmin                       Boolean                      @default(false)
  companyId                          String?
  createdAt                          DateTime                     @default(now())
  updatedAt                          DateTime                     @updatedAt
  deletedAt                          DateTime?
  lastLoginAt                        DateTime?
  refreshToken                       String?
  hasSeenTour                        Boolean                      @default(false)
  createdAccountPayablePayments      AccountPayablePayment[]      @relation("AccountPayablePaymentCreatedBy")
  auditLogs                          AuditLog[]
  approvedCarteraAdjustments         CarteraAdjustment[]          @relation("CarteraAdjustmentApprovedBy")
  requestedCarteraAdjustments        CarteraAdjustment[]          @relation("CarteraAdjustmentRequestedBy")
  importedCarteraBankMovements       CarteraBankMovement[]        @relation("CarteraBankMovementImportedBy")
  reconciledCarteraBankMovements     CarteraBankMovement[]        @relation("CarteraBankMovementReconciledBy")
  createdCarteraCollectionFollowUps  CarteraCollectionFollowUp[]  @relation("CarteraCollectionFollowUpCreatedBy")
  createdCarteraPaymentPromises      CarteraPaymentPromise[]      @relation("CarteraPaymentPromiseCreatedBy")
  carteraPayments                    CarteraPayment[]
  carteraReceiptApplications         CarteraReceiptApplication[]
  carteraReceipts                    CarteraReceipt[]
  importJobs                         ImportJob[]
  posCashMovements                   PosCashMovement[]
  pos_sessions                       PosSession[]
  approvedPurchaseAdjustments        PurchaseAdjustment[]         @relation("PurchaseAdjustmentApprovedBy")
  createdPurchaseAdjustments         PurchaseAdjustment[]         @relation("PurchaseAdjustmentCreatedBy")
  createdPurchaseAdvances            PurchaseAdvance[]            @relation("PurchaseAdvanceCreatedBy")
  createdPurchaseBudgets             PurchaseBudget[]             @relation("PurchaseBudgetCreatedBy")
  createdPurchaseFrameworkAgreements PurchaseFrameworkAgreement[] @relation("PurchaseFrameworkAgreementCreatedBy")
  createdPurchaseInvoices            PurchaseInvoice[]            @relation("PurchaseInvoiceCreatedBy")
  createdPurchaseOrderReceipts       PurchaseOrderReceipt[]       @relation("PurchaseOrderReceiptCreatedBy")
  approvedPurchaseRequestApprovals   PurchaseRequestApproval[]    @relation("PurchaseRequestApprovalApprovedBy")
  createdPurchaseRequests            PurchaseRequest[]            @relation("PurchaseRequestCreatedBy")
  createdPurchaseSupplierQuotes      PurchaseSupplierQuote[]      @relation("PurchaseSupplierQuoteCreatedBy")
  approvedQuoteApprovalRequests      QuoteApprovalRequest[]       @relation("QuoteApprovalApprovedBy")
  requestedQuoteApprovalRequests     QuoteApprovalRequest[]       @relation("QuoteApprovalRequestedBy")
  quote_attachments                  QuoteAttachment[]
  quote_comments                     QuoteComment[]
  quoteFollowUps                     QuoteFollowUp[]
  quoteVersions                      QuoteVersion[]
  userBranches                       UserBranch[]
  roles                              UserRole[]
  company                            Company?                     @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  displayName String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model RolePermission {
  id       String @id @default(uuid())
  roleId   String
  resource String
  action   String
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Category {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  company     Company    @relation(fields: [companyId], references: [id])
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("categories")
}

model Product {
  id                              String                           @id @default(uuid())
  companyId                       String
  categoryId                      String?
  sku                             String
  name                            String
  description                     String?
  price                           Decimal                          @db.Decimal(12, 2)
  cost                            Decimal                          @default(0) @db.Decimal(12, 2)
  stock                           Int                              @default(0)
  minStock                        Int                              @default(0)
  unit                            String                           @default("UND")
  taxRate                         Decimal                          @default(19) @db.Decimal(5, 2)
  taxType                         TaxType                          @default(IVA)
  unspscCode                      String?
  status                          ProductStatus                    @default(ACTIVE)
  imageUrl                        String?
  barcode                         String?
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt
  deletedAt                       DateTime?
  branchId                        String?
  invoiceItems                    InvoiceItem[]
  posSaleItems                    PosSaleItem[]
  branch                          Branch?                          @relation(fields: [branchId], references: [id])
  category                        Category?                        @relation(fields: [categoryId], references: [id])
  company                         Company                          @relation(fields: [companyId], references: [id])
  purchaseFrameworkAgreementItems PurchaseFrameworkAgreementItem[]
  purchaseInventoryMovements      PurchaseInventoryMovement[]
  purchaseOrderItems              PurchaseOrderItem[]
  purchaseRequestItems            PurchaseRequestItem[]
  quoteItems                      QuoteItem[]
  quote_price_list_items          QuotePriceListItem[]
  quote_template_items            QuoteTemplateItem[]

  @@index([companyId, branchId, sku])
  @@index([branchId])
  @@index([companyId])
  @@index([companyId, status])
  @@map("products")
}

model Customer {
  id                          String                       @id @default(uuid())
  companyId                   String
  documentType                DocumentType                 @default(NIT)
  documentNumber              String
  name                        String
  email                       String?
  phone                       String?
  address                     String?
  city                        String?
  department                  String?
  cityCode                    String?
  departmentCode              String?
  country                     String                       @default("CO")
  isActive                    Boolean                      @default(true)
  creditLimit                 Decimal?                     @db.Decimal(12, 2)
  creditDays                  Int?
  notes                       String?
  taxLevelCode                String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  deletedAt                   DateTime?
  accountsPayable             AccountPayable[]
  carteraAdjustments          CarteraAdjustment[]
  carteraCollectionFollowUps  CarteraCollectionFollowUp[]
  carteraPaymentPromises      CarteraPaymentPromise[]
  carteraReceipts             CarteraReceipt[]
  company                     Company                      @relation(fields: [companyId], references: [id])
  invoices                    Invoice[]
  pos_sales                   PosSale[]
  purchaseAdjustments         PurchaseAdjustment[]
  purchaseAdvances            PurchaseAdvance[]
  purchaseFrameworkAgreements PurchaseFrameworkAgreement[]
  purchaseInvoices            PurchaseInvoice[]
  purchaseOrders              PurchaseOrder[]
  purchaseRequests            PurchaseRequest[]
  purchaseSupplierQuotes      PurchaseSupplierQuote[]
  quotes                      Quote[]

  @@unique([companyId, documentType, documentNumber])
  @@index([companyId])
  @@map("customers")
}

model Invoice {
  id                         String                      @id @default(uuid())
  companyId                  String
  customerId                 String
  invoiceNumber              String
  prefix                     String                      @default("FV")
  type                       InvoiceType                 @default(VENTA)
  status                     InvoiceStatus               @default(DRAFT)
  issueDate                  DateTime
  dueDate                    DateTime?
  subtotal                   Decimal                     @db.Decimal(12, 2)
  taxAmount                  Decimal                     @db.Decimal(12, 2)
  discountAmount             Decimal                     @default(0) @db.Decimal(12, 2)
  total                      Decimal                     @db.Decimal(12, 2)
  notes                      String?
  dianCufe                   String?                     @unique
  dianQrCode                 String?
  dianStatus                 String?
  dianStatusCode             String?
  dianStatusMsg              String?
  dianErrors                 String?
  dianZipKey                 String?
  dianXmlBase64              String?
  dianSentAt                 DateTime?
  dianResponseAt             DateTime?
  dianAttempts               Int                         @default(0)
  xmlContent                 String?
  xmlSigned                  String?
  pdfUrl                     String?
  xmlUrl                     String?
  currency                   String                      @default("COP")
  exchangeRate               Decimal                     @default(1) @db.Decimal(12, 4)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  deletedAt                  DateTime?
  dianCude                   String?                     @unique
  discrepancyReason          String?
  discrepancyReasonCode      String?
  originalInvoiceId          String?
  branchId                   String?
  carteraAdjustments         CarteraAdjustment[]         @relation("CarteraAdjustmentInvoice")
  sourceCarteraAdjustments   CarteraAdjustment[]         @relation("CarteraAdjustmentSourceInvoice")
  carteraCollectionFollowUps CarteraCollectionFollowUp[]
  carteraPaymentPromises     CarteraPaymentPromise[]
  payments                   CarteraPayment[]
  receiptApplications        CarteraReceiptApplication[]
  items                      InvoiceItem[]
  branch                     Branch?                     @relation(fields: [branchId], references: [id])
  company                    Company                     @relation(fields: [companyId], references: [id])
  customer                   Customer                    @relation(fields: [customerId], references: [id])
  originalInvoice            Invoice?                    @relation("InvoiceNotes", fields: [originalInvoiceId], references: [id])
  creditDebitNotes           Invoice[]                   @relation("InvoiceNotes")
  payrollRecord              payroll_records?            @relation("PayrollInvoice")
  posSale                    PosSale?                    @relation("PosSaleInvoice")
  quote                      Quote?                      @relation("QuoteInvoice")

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@index([originalInvoiceId])
  @@index([branchId])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  taxAmount   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  total       Decimal  @db.Decimal(12, 2)
  position    Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model CarteraPayment {
  id            String   @id @default(uuid())
  companyId     String
  invoiceId     String
  userId        String
  amount        Decimal  @db.Decimal(12, 2)
  paymentMethod String
  reference     String?
  notes         String?
  paymentDate   DateTime
  createdAt     DateTime @default(now())
  company       Company  @relation(fields: [companyId], references: [id])
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@index([invoiceId])
  @@index([companyId, paymentDate])
  @@map("cartera_payments")
}

model CarteraReceipt {
  id              String                      @id
  companyId       String
  customerId      String
  number          String
  amount          Decimal                     @db.Decimal(12, 2)
  appliedAmount   Decimal                     @default(0) @db.Decimal(12, 2)
  unappliedAmount Decimal                     @db.Decimal(12, 2)
  paymentMethod   String
  reference       String?
  notes           String?
  paymentDate     DateTime
  status          String                      @default("OPEN")
  createdById     String
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  adjustments     CarteraAdjustment[]
  bankMovements   CarteraBankMovement[]
  applications    CarteraReceiptApplication[]
  company         Company                     @relation(fields: [companyId], references: [id])
  createdBy       User                        @relation(fields: [createdById], references: [id])
  customer        Customer                    @relation(fields: [customerId], references: [id])

  @@unique([companyId, number])
  @@index([companyId, paymentDate])
  @@index([customerId])
  @@map("cartera_receipts")
}

model CarteraReceiptApplication {
  id          String         @id
  companyId   String
  receiptId   String
  invoiceId   String
  amount      Decimal        @db.Decimal(12, 2)
  appliedAt   DateTime
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  company     Company        @relation(fields: [companyId], references: [id])
  createdBy   User           @relation(fields: [createdById], references: [id])
  invoice     Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  receipt     CarteraReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([companyId, appliedAt])
  @@index([receiptId])
  @@index([invoiceId])
  @@map("cartera_receipt_applications")
}

model CarteraPaymentPromise {
  id           String    @id
  companyId    String
  customerId   String
  invoiceId    String?
  amount       Decimal   @db.Decimal(12, 2)
  promisedDate DateTime
  status       String    @default("OPEN")
  notes        String?
  createdById  String
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  company      Company   @relation(fields: [companyId], references: [id])
  createdBy    User      @relation("CarteraPaymentPromiseCreatedBy", fields: [createdById], references: [id])
  customer     Customer  @relation(fields: [customerId], references: [id])
  invoice      Invoice?  @relation(fields: [invoiceId], references: [id])

  @@index([companyId, promisedDate])
  @@index([customerId])
  @@index([invoiceId])
  @@map("cartera_payment_promises")
}

model CarteraCollectionFollowUp {
  id             String    @id
  companyId      String
  customerId     String
  invoiceId      String?
  activityType   String
  outcome        String
  nextActionDate DateTime?
  nextAction     String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  company        Company   @relation(fields: [companyId], references: [id])
  createdBy      User      @relation("CarteraCollectionFollowUpCreatedBy", fields: [createdById], references: [id])
  customer       Customer  @relation(fields: [customerId], references: [id])
  invoice        Invoice?  @relation(fields: [invoiceId], references: [id])

  @@index([companyId, createdAt])
  @@index([customerId])
  @@index([invoiceId])
  @@map("cartera_collection_followups")
}

model CarteraAdjustment {
  id              String          @id
  companyId       String
  customerId      String
  invoiceId       String?
  receiptId       String?
  sourceInvoiceId String?
  type            String
  status          String          @default("PENDING_APPROVAL")
  amount          Decimal         @db.Decimal(12, 2)
  reason          String
  notes           String?
  requestedById   String
  approvedById    String?
  approvedAt      DateTime?
  appliedAt       DateTime?
  rejectedAt      DateTime?
  rejectedReason  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now()) @updatedAt
  approvedBy      User?           @relation("CarteraAdjustmentApprovedBy", fields: [approvedById], references: [id])
  company         Company         @relation(fields: [companyId], references: [id])
  customer        Customer        @relation(fields: [customerId], references: [id])
  invoice         Invoice?        @relation("CarteraAdjustmentInvoice", fields: [invoiceId], references: [id])
  receipt         CarteraReceipt? @relation(fields: [receiptId], references: [id])
  requestedBy     User            @relation("CarteraAdjustmentRequestedBy", fields: [requestedById], references: [id])
  sourceInvoice   Invoice?        @relation("CarteraAdjustmentSourceInvoice", fields: [sourceInvoiceId], references: [id])

  @@index([companyId, createdAt])
  @@index([customerId])
  @@index([invoiceId])
  @@index([receiptId])
  @@index([status, type])
  @@map("cartera_adjustments")
}

model CarteraBankMovement {
  id               String          @id
  companyId        String
  bankCode         String?
  accountNumber    String?
  movementDate     DateTime
  reference        String?
  description      String?
  amount           Decimal         @db.Decimal(12, 2)
  status           String          @default("UNRECONCILED")
  matchedReceiptId String?
  reconciledById   String?
  reconciledAt     DateTime?
  importedById     String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @default(now()) @updatedAt
  company          Company         @relation(fields: [companyId], references: [id])
  importedBy       User            @relation("CarteraBankMovementImportedBy", fields: [importedById], references: [id])
  matchedReceipt   CarteraReceipt? @relation(fields: [matchedReceiptId], references: [id])
  reconciledBy     User?           @relation("CarteraBankMovementReconciledBy", fields: [reconciledById], references: [id])

  @@index([companyId, movementDate])
  @@index([status])
  @@index([matchedReceiptId])
  @@map("cartera_bank_movements")
}

model Integration {
  id         String            @id @default(uuid())
  companyId  String
  type       IntegrationType
  name       String
  config     Json
  isActive   Boolean           @default(true)
  lastSyncAt DateTime?
  status     IntegrationStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  company    Company           @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("integrations")
}

model UsageTracking {
  id        String   @id @default(uuid())
  companyId String
  metric    String
  value     Int      @default(0)
  period    String
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, metric, period])
  @@index([companyId, period])
  @@map("usage_tracking")
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String?
  userId     String?
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  company    Company? @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

model ImportJob {
  id            String        @id @default(uuid())
  companyId     String
  userId        String
  type          String        @default("PRODUCTS")
  status        ImportStatus  @default(PENDING)
  fileName      String
  fileUrl       String
  totalRows     Int           @default(0)
  processedRows Int           @default(0)
  successRows   Int           @default(0)
  errorRows     Int           @default(0)
  reportUrl     String?
  startedAt     DateTime?
  completedAt   DateTime?
