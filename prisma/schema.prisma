// BeccaFact - Prisma Schema
// Multi-tenant SaaS ERP for Colombia

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// PLANS & FEATURES
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id          String   @id @default(uuid())
  name        String   @unique // BASIC | EMPRESARIAL | CORPORATIVO
  displayName String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("COP")
  isActive    Boolean  @default(true)
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  features      PlanFeature[]
  subscriptions Subscription[]

  @@map("plans")
}

model PlanFeature {
  id     String @id @default(uuid())
  planId String
  key    String // max_documents_per_month | max_products | max_integrations | storage_months | etc.
  value  String // "300" | "unlimited" | "true" | "false"
  label  String?

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@map("plan_features")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPANIES
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id             String        @id @default(uuid())
  name           String
  nit            String        @unique
  razonSocial    String
  email          String
  phone          String?
  address        String?
  city           String?
  department     String?
  country        String        @default("CO")
  status         CompanyStatus @default(ACTIVE)
  dianApiKey     String?       @db.Text
  dianTestMode   Boolean       @default(true)
  logoUrl        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  users          User[]
  subscriptions  Subscription[]
  products       Product[]
  categories     Category[]
  invoices       Invoice[]
  customers      Customer[]
  integrations   Integration[]
  usageTracking  UsageTracking[]
  auditLogs      AuditLog[]
  importJobs     ImportJob[]
  employees      Employee[]
  payrollRecords PayrollRecord[]

  @@index([status])
  @@index([nit])
  @@map("companies")
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

// ─────────────────────────────────────────────────────────────────────────────
// SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Subscription {
  id               String             @id @default(uuid())
  companyId        String
  planId           String
  status           SubscriptionStatus @default(ACTIVE)
  startDate        DateTime
  endDate          DateTime?
  trialEndsAt      DateTime?
  customLimits     Json?              // Override per-company limits
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
  EXPIRED
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & ROLES
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  avatar         String?
  isActive       Boolean   @default(true)
  isSuperAdmin   Boolean   @default(false)
  companyId      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  lastLoginAt    DateTime?
  refreshToken   String?   @db.Text

  company        Company?         @relation(fields: [companyId], references: [id])
  roles          UserRole[]
  auditLogs      AuditLog[]
  importJobs     ImportJob[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // SUPER_ADMIN | ADMIN | MANAGER | OPERATOR | VIEWER
  displayName String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model RolePermission {
  id         String @id @default(uuid())
  roleId     String
  resource   String // invoices | products | customers | reports | etc.
  action     String // create | read | update | delete | export | import

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTS & CATEGORIES
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company  Company    @relation(fields: [companyId], references: [id])
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("categories")
}

model Product {
  id           String        @id @default(uuid())
  companyId    String
  categoryId   String?
  sku          String
  name         String
  description  String?       @db.Text
  price        Decimal       @db.Decimal(12, 2)
  cost         Decimal       @default(0) @db.Decimal(12, 2)
  stock        Int           @default(0)
  minStock     Int           @default(0)
  unit         String        @default("UND")
  taxRate      Decimal       @default(19) @db.Decimal(5, 2)
  taxType      TaxType       @default(IVA)
  status       ProductStatus @default(ACTIVE)
  imageUrl     String?
  barcode      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  company      Company       @relation(fields: [companyId], references: [id])
  category     Category?     @relation(fields: [categoryId], references: [id])
  invoiceItems InvoiceItem[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([companyId, status])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum TaxType {
  IVA
  INC
  ICA
  NONE
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id             String       @id @default(uuid())
  companyId      String
  documentType   DocumentType @default(NIT)
  documentNumber String
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  department     String?
  country        String       @default("CO")
  isActive       Boolean      @default(true)
  creditLimit    Decimal?     @db.Decimal(12, 2)
  creditDays     Int?
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  company  Company   @relation(fields: [companyId], references: [id])
  invoices Invoice[]

  @@unique([companyId, documentType, documentNumber])
  @@index([companyId])
  @@map("customers")
}

enum DocumentType {
  NIT
  CC
  CE
  PASSPORT
  TI
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(uuid())
  companyId       String
  customerId      String
  invoiceNumber   String
  prefix          String        @default("FV")
  type            InvoiceType   @default(VENTA)
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime
  dueDate         DateTime?
  subtotal        Decimal       @db.Decimal(12, 2)
  taxAmount       Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  notes           String?       @db.Text
  dianCufe        String?       @unique
  dianQrCode      String?       @db.Text
  dianStatus      String?
  dianStatusCode  String?
  dianStatusMsg   String?       @db.Text
  dianZipKey      String?
  dianAttempts    Int           @default(0)
  dianSentAt      DateTime?
  dianResponseAt  DateTime?
  dianXmlBase64   String?       @db.Text
  xmlContent      String?       @db.Text
  xmlSigned       String?       @db.Text
  pdfUrl          String?
  xmlUrl          String?
  currency        String        @default("COP")
  exchangeRate    Decimal       @default(1) @db.Decimal(12, 4)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  company  Company       @relation(fields: [companyId], references: [id])
  customer Customer      @relation(fields: [customerId], references: [id])
  items    InvoiceItem[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(12, 4)
  unitPrice   Decimal @db.Decimal(12, 2)
  taxRate     Decimal @db.Decimal(5, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  total       Decimal @db.Decimal(12, 2)
  position    Int

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

enum InvoiceType {
  VENTA
  NOTA_CREDITO
  NOTA_DEBITO
  SOPORTE_ADQUISICION
}

enum InvoiceStatus {
  DRAFT
  SENT_DIAN
  ACCEPTED_DIAN
  REJECTED_DIAN
  PAID
  CANCELLED
  OVERDUE
}

// ─────────────────────────────────────────────────────────────────────────────
// INTEGRATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Integration {
  id          String            @id @default(uuid())
  companyId   String
  type        IntegrationType
  name        String
  config      Json
  isActive    Boolean           @default(true)
  lastSyncAt  DateTime?
  status      IntegrationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("integrations")
}

enum IntegrationType {
  DIAN
  NOMINA
  CONTABILIDAD
  BANCOS
  ECOMMERCE
  CUSTOM
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  ERROR
  SUSPENDED
}

// ─────────────────────────────────────────────────────────────────────────────
// USAGE TRACKING
// ─────────────────────────────────────────────────────────────────────────────

model UsageTracking {
  id          String   @id @default(uuid())
  companyId   String
  metric      String   // documents_issued | products_created | storage_used
  value       Int      @default(0)
  period      String   // YYYY-MM
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, metric, period])
  @@index([companyId, period])
  @@map("usage_tracking")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String?
  userId     String?
  action     String   // CREATE | UPDATE | DELETE | LOGIN | EXPORT | etc.
  resource   String   // invoice | product | user | etc.
  resourceId String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// IMPORT JOBS
// ─────────────────────────────────────────────────────────────────────────────

model ImportJob {
  id           String      @id @default(uuid())
  companyId    String
  userId       String
  type         String      @default("PRODUCTS")
  status       ImportStatus @default(PENDING)
  fileName     String
  fileUrl      String
  totalRows    Int         @default(0)
  processedRows Int        @default(0)
  successRows  Int         @default(0)
  errorRows    Int         @default(0)
  reportUrl    String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company Company       @relation(fields: [companyId], references: [id])
  user    User          @relation(fields: [userId], references: [id])
  errors  ImportError[]

  @@index([companyId])
  @@index([status])
  @@map("import_jobs")
}

model ImportError {
  id         String   @id @default(uuid())
  importJobId String
  rowNumber  Int
  field      String?
  value      String?
  message    String
  rawData    Json?
  createdAt  DateTime @default(now())

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@map("import_errors")
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYROLL — Nómina Electrónica
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id             String    @id @default(uuid())
  companyId      String
  documentType   String    @default("CC")   // CC | CE | PASSPORT | NIT
  documentNumber String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  position       String                      // job title / cargo
  baseSalary     Decimal   @db.Decimal(12, 2)
  contractType   String    @default("INDEFINITE") // INDEFINITE | FIXED | PROJECT | APPRENTICE
  hireDate       DateTime
  city           String?
  bankAccount    String?
  bankName       String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  company       Company         @relation(fields: [companyId], references: [id])
  payrollRecords PayrollRecord[]

  @@unique([companyId, documentNumber])
  @@index([companyId])
  @@map("employees")
}

model PayrollRecord {
  id         String   @id @default(uuid())
  companyId  String
  employeeId String
  period     String   // YYYY-MM
  payDate    DateTime
  status     String   @default("DRAFT")
  // DRAFT | PROCESSING | SUBMITTED | ACCEPTED | REJECTED | VOIDED
  cune       String?  @unique  // DIAN electronic payroll code

  // Earnings
  baseSalary        Decimal  @db.Decimal(12, 2)
  daysWorked        Int      @default(30)
  overtimeHours     Decimal  @default(0) @db.Decimal(8, 2)
  bonuses           Decimal  @default(0) @db.Decimal(12, 2)
  commissions       Decimal  @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal @default(0) @db.Decimal(12, 2)
  vacationPay       Decimal  @default(0) @db.Decimal(12, 2)

  // Employee deductions
  healthEmployee    Decimal  @default(0) @db.Decimal(12, 2)
  pensionEmployee   Decimal  @default(0) @db.Decimal(12, 2)
  sickLeave         Decimal  @default(0) @db.Decimal(12, 2)
  loans             Decimal  @default(0) @db.Decimal(12, 2)
  otherDeductions   Decimal  @default(0) @db.Decimal(12, 2)

  // Employer contributions
  healthEmployer    Decimal  @default(0) @db.Decimal(12, 2)
  pensionEmployer   Decimal  @default(0) @db.Decimal(12, 2)
  arl               Decimal  @default(0) @db.Decimal(12, 2)
  compensationFund  Decimal  @default(0) @db.Decimal(12, 2)

  // Calculated totals
  totalEarnings     Decimal  @db.Decimal(12, 2)
  totalDeductions   Decimal  @db.Decimal(12, 2)
  netPay            Decimal  @db.Decimal(12, 2)
  totalEmployerCost Decimal  @db.Decimal(12, 2)

  notes        String?
  submittedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([companyId, employeeId, period])
  @@index([companyId])
  @@index([companyId, period])
  @@map("payroll_records")
}