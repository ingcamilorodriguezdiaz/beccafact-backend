  @@index([status])
  @@index([quoteId, sequence])
  @@map("quote_approval_requests")
}

model QuoteApprovalPolicy {
  id             String   @id
  companyId      String
  name           String
  approvalType   String
  thresholdValue Decimal  @db.Decimal(14, 2)
  requiredRole   String
  sequence       Int      @default(1)
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  companies      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId, isActive, sequence])
  @@map("quote_approval_policies")
}

model QuoteAttachment {
  id           String   @id
  companyId    String
  quoteId      String
  fileName     String
  fileUrl      String
  mimeType     String?
  category     String?
  notes        String?
  sizeBytes    Int?
  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  companies    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quotes       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  users        User?    @relation(fields: [uploadedById], references: [id])

  @@index([companyId, quoteId, createdAt])
  @@map("quote_attachments")
}

model QuoteComment {
  id          String   @id
  companyId   String
  quoteId     String
  commentType String   @default("INTERNAL")
  message     String
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  companies   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users       User?    @relation(fields: [createdById], references: [id])
  quotes      Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([companyId, quoteId, createdAt])
  @@map("quote_comments")
}

model QuoteFollowUp {
  id           String    @id
  companyId    String
  quoteId      String
  activityType String
  notes        String
  scheduledAt  DateTime?
  createdById  String?
  createdAt    DateTime  @default(now())
  company      Company   @relation(fields: [companyId], references: [id])
  createdBy    User?     @relation(fields: [createdById], references: [id])
  quote        Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([companyId, quoteId])
  @@map("quote_followups")
}

