generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id            String         @id @default(uuid())
  name          String         @unique
  displayName   String
  description   String?
  price         Decimal        @db.Decimal(12, 2)
  currency      String         @default("COP")
  isActive      Boolean        @default(true)
  isCustom      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  features      PlanFeature[]
  subscriptions Subscription[]

  @@map("plans")
}

model PlanFeature {
  id     String  @id @default(uuid())
  planId String
  key    String
  value  String
  label  String?
  plan   Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@map("plan_features")
}

model Company {
  id                         String                      @id @default(uuid())
  name                       String
  nit                        String                      @unique
  razonSocial                String
  email                      String
  phone                      String?
  address                    String?
  city                       String?
  department                 String?
  cityCode                   String?
  departmentCode             String?
  country                    String                      @default("CO")
  status                     CompanyStatus               @default(ACTIVE)
  dianTestMode               Boolean                     @default(true)
  dianSoftwareId             String?
  dianSoftwarePin            String?
  dianTestSetId              String?
  dianClaveTecnica           String?
  dianResolucion             String?
  dianPrefijo                String?
  dianRangoDesde             Int?
  dianRangoHasta             Int?
  dianFechaDesde             String?
  dianFechaHasta             String?
  dianCertificate            String?
  dianCertificateKey         String?
  logoUrl                    String?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  deletedAt                  DateTime?
  nominaSoftwareId           String?
  nominaSoftwarePin          String?
  nominaTestSetId            String?
  dianPosResolucion          String?
  dianPosPrefijo             String?
  dianPosRangoDesde          Int?
  dianPosRangoHasta          Int?
  dianPosFechaDesde          String?
  dianPosFechaHasta          String?
  accountingAccounts         AccountingAccount[]
  accountingPeriods          AccountingPeriod[]
  auditLogs                  AuditLog[]
  branches                   Branch[]
  carteraAdjustments         CarteraAdjustment[]
  carteraCollectionFollowUps CarteraCollectionFollowUp[]
  carteraPaymentPromises     CarteraPaymentPromise[]
  carteraPayments            CarteraPayment[]
  carteraReceiptApplications CarteraReceiptApplication[]
  carteraReceipts            CarteraReceipt[]
  carteraBankMovements       CarteraBankMovement[]
  categories                 Category[]
  customers                  Customer[]
  dianTestSets               DianTestSet[]
  employees                  employees[]
  importJobs                 ImportJob[]
  integrations               Integration[]
  invoices                   Invoice[]
  journalEntries             JournalEntry[]
  payroll_records            payroll_records[]
  posCashMovements           PosCashMovement[]
  pos_sales                  PosSale[]
  pos_sessions               PosSession[]
  products                   Product[]
  purchaseOrders             PurchaseOrder[]
  quotes                     Quote[]
  subscriptions              Subscription[]
  usageTracking              UsageTracking[]
  users                      User[]

  @@index([status])
  @@index([nit])
  @@map("companies")
}

model Branch {
  id              String            @id @default(uuid())
  companyId       String
  name            String
  address         String?
  city            String?
  department      String?
  phone           String?
  email           String?
  isMain          Boolean           @default(false)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  cityCode        String?
  country         String?           @default("CO")
  departmentCode  String?
  company         Company           @relation(fields: [companyId], references: [id])
  employees       employees[]       @relation("EmployeeBranch")
  invoices        Invoice[]
  payroll_records payroll_records[] @relation("PayrollBranch")
  posSales        PosSale[]
  posSessions     PosSession[]
  products        Product[]
  userBranches    UserBranch[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, isActive])
  @@map("branches")
}

model UserBranch {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  companyId String
  createdAt DateTime @default(now())
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([companyId])
  @@map("user_branches")
}

model Subscription {
  id           String             @id @default(uuid())
  companyId    String
  planId       String
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?
  trialEndsAt  DateTime?
  customLimits Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  company      Company            @relation(fields: [companyId], references: [id])
  plan         Plan               @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

model User {
  id                                String                      @id @default(uuid())
  email                             String                      @unique
  password                          String
  firstName                         String
  lastName                          String
  phone                             String?
  avatar                            String?
  isActive                          Boolean                     @default(true)
  isSuperAdmin                      Boolean                     @default(false)
  companyId                         String?
  createdAt                         DateTime                    @default(now())
  updatedAt                         DateTime                    @updatedAt
  deletedAt                         DateTime?
  lastLoginAt                       DateTime?
  refreshToken                      String?
  hasSeenTour                       Boolean                     @default(false)
  auditLogs                         AuditLog[]
  approvedCarteraAdjustments        CarteraAdjustment[]         @relation("CarteraAdjustmentApprovedBy")
  importedCarteraBankMovements      CarteraBankMovement[]       @relation("CarteraBankMovementImportedBy")
  reconciledCarteraBankMovements    CarteraBankMovement[]       @relation("CarteraBankMovementReconciledBy")
  requestedCarteraAdjustments       CarteraAdjustment[]         @relation("CarteraAdjustmentRequestedBy")
  createdCarteraCollectionFollowUps CarteraCollectionFollowUp[] @relation("CarteraCollectionFollowUpCreatedBy")
  createdCarteraPaymentPromises     CarteraPaymentPromise[]     @relation("CarteraPaymentPromiseCreatedBy")
  carteraPayments                   CarteraPayment[]
  carteraReceiptApplications        CarteraReceiptApplication[]
  carteraReceipts                   CarteraReceipt[]
  importJobs                        ImportJob[]
  posCashMovements                  PosCashMovement[]
  pos_sessions                      PosSession[]
  userBranches                      UserBranch[]
  roles                             UserRole[]
  company                           Company?                    @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  displayName String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model RolePermission {
  id       String @id @default(uuid())
  roleId   String
  resource String
  action   String
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Category {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  company     Company    @relation(fields: [companyId], references: [id])
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("categories")
}

model Product {
  id                 String              @id @default(uuid())
  companyId          String
  categoryId         String?
  sku                String
  name               String
  description        String?
  price              Decimal             @db.Decimal(12, 2)
  cost               Decimal             @default(0) @db.Decimal(12, 2)
  stock              Int                 @default(0)
  minStock           Int                 @default(0)
  unit               String              @default("UND")
  taxRate            Decimal             @default(19) @db.Decimal(5, 2)
  taxType            TaxType             @default(IVA)
  unspscCode         String?
  status             ProductStatus       @default(ACTIVE)
  imageUrl           String?
  barcode            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  branchId           String?
  invoiceItems       InvoiceItem[]
  posSaleItems       PosSaleItem[]
  branch             Branch?             @relation(fields: [branchId], references: [id])
  category           Category?           @relation(fields: [categoryId], references: [id])
  company            Company             @relation(fields: [companyId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  quoteItems         QuoteItem[]

  @@index([companyId, branchId, sku])
  @@index([branchId])
  @@index([companyId])
  @@index([companyId, status])
  @@map("products")
}

model Customer {
  id                         String                      @id @default(uuid())
  companyId                  String
  documentType               DocumentType                @default(NIT)
  documentNumber             String
  name                       String
  email                      String?
  phone                      String?
  address                    String?
  city                       String?
  department                 String?
  cityCode                   String?
  departmentCode             String?
  country                    String                      @default("CO")
  isActive                   Boolean                     @default(true)
  creditLimit                Decimal?                    @db.Decimal(12, 2)
  creditDays                 Int?
  notes                      String?
  taxLevelCode               String?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  deletedAt                  DateTime?
  carteraAdjustments         CarteraAdjustment[]
  carteraCollectionFollowUps CarteraCollectionFollowUp[]
  carteraPaymentPromises     CarteraPaymentPromise[]
  carteraReceipts            CarteraReceipt[]
  company                    Company                     @relation(fields: [companyId], references: [id])
  invoices                   Invoice[]
  pos_sales                  PosSale[]
  purchaseOrders             PurchaseOrder[]
  quotes                     Quote[]

  @@unique([companyId, documentType, documentNumber])
  @@index([companyId])
  @@map("customers")
}

model Invoice {
  id                         String                      @id @default(uuid())
  companyId                  String
  customerId                 String
  invoiceNumber              String
  prefix                     String                      @default("FV")
  type                       InvoiceType                 @default(VENTA)
  status                     InvoiceStatus               @default(DRAFT)
  issueDate                  DateTime
  dueDate                    DateTime?
  subtotal                   Decimal                     @db.Decimal(12, 2)
  taxAmount                  Decimal                     @db.Decimal(12, 2)
  discountAmount             Decimal                     @default(0) @db.Decimal(12, 2)
  total                      Decimal                     @db.Decimal(12, 2)
  notes                      String?
  dianCufe                   String?                     @unique
  dianQrCode                 String?
  dianStatus                 String?
  dianStatusCode             String?
  dianStatusMsg              String?
  dianErrors                 String?
  dianZipKey                 String?
  dianXmlBase64              String?
  dianSentAt                 DateTime?
  dianResponseAt             DateTime?
  dianAttempts               Int                         @default(0)
  xmlContent                 String?
  xmlSigned                  String?
  pdfUrl                     String?
  xmlUrl                     String?
  currency                   String                      @default("COP")
  exchangeRate               Decimal                     @default(1) @db.Decimal(12, 4)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  deletedAt                  DateTime?
  dianCude                   String?                     @unique
  discrepancyReason          String?
  discrepancyReasonCode      String?
  originalInvoiceId          String?
  branchId                   String?
  carteraAdjustments         CarteraAdjustment[]         @relation("CarteraAdjustmentInvoice")
  sourceCarteraAdjustments   CarteraAdjustment[]         @relation("CarteraAdjustmentSourceInvoice")
  carteraCollectionFollowUps CarteraCollectionFollowUp[]
  carteraPaymentPromises     CarteraPaymentPromise[]
  payments                   CarteraPayment[]
  receiptApplications        CarteraReceiptApplication[]
  items                      InvoiceItem[]
  branch                     Branch?                     @relation(fields: [branchId], references: [id])
  company                    Company                     @relation(fields: [companyId], references: [id])
  customer                   Customer                    @relation(fields: [customerId], references: [id])
  originalInvoice            Invoice?                    @relation("InvoiceNotes", fields: [originalInvoiceId], references: [id])
  creditDebitNotes           Invoice[]                   @relation("InvoiceNotes")
  payrollRecord              payroll_records?            @relation("PayrollInvoice")
  posSale                    PosSale?                    @relation("PosSaleInvoice")
  quote                      Quote?                      @relation("QuoteInvoice")

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@index([originalInvoiceId])
  @@index([branchId])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  taxAmount   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  total       Decimal  @db.Decimal(12, 2)
  position    Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model CarteraPayment {
  id            String   @id @default(uuid())
  companyId     String
  invoiceId     String
  userId        String
  amount        Decimal  @db.Decimal(12, 2)
  paymentMethod String
  reference     String?
  notes         String?
  paymentDate   DateTime
  createdAt     DateTime @default(now())
  company       Company  @relation(fields: [companyId], references: [id])
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@index([invoiceId])
  @@index([companyId, paymentDate])
  @@map("cartera_payments")
}

model CarteraReceipt {
  id              String                      @id
  companyId       String
  customerId      String
  number          String
  amount          Decimal                     @db.Decimal(12, 2)
  appliedAmount   Decimal                     @default(0) @db.Decimal(12, 2)
  unappliedAmount Decimal                     @db.Decimal(12, 2)
  paymentMethod   String
  reference       String?
  notes           String?
  paymentDate     DateTime
  status          String                      @default("OPEN")
  createdById     String
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  adjustments     CarteraAdjustment[]
  applications    CarteraReceiptApplication[]
  bankMovements   CarteraBankMovement[]
  company         Company                     @relation(fields: [companyId], references: [id])
  createdBy       User                        @relation(fields: [createdById], references: [id])
  customer        Customer                    @relation(fields: [customerId], references: [id])

  @@unique([companyId, number])
  @@index([companyId, paymentDate])
  @@index([customerId])
  @@map("cartera_receipts")
}

model CarteraReceiptApplication {
  id          String         @id
  companyId   String
  receiptId   String
  invoiceId   String
  amount      Decimal        @db.Decimal(12, 2)
  appliedAt   DateTime
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  company     Company        @relation(fields: [companyId], references: [id])
  createdBy   User           @relation(fields: [createdById], references: [id])
  invoice     Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  receipt     CarteraReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([companyId, appliedAt])
  @@index([receiptId])
  @@index([invoiceId])
  @@map("cartera_receipt_applications")
}

model CarteraPaymentPromise {
  id           String    @id
  companyId    String
  customerId   String
  invoiceId    String?
  amount       Decimal   @db.Decimal(12, 2)
  promisedDate DateTime
  status       String    @default("OPEN")
  notes        String?
  createdById  String
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  company      Company   @relation(fields: [companyId], references: [id])
  createdBy    User      @relation("CarteraPaymentPromiseCreatedBy", fields: [createdById], references: [id])
  customer     Customer  @relation(fields: [customerId], references: [id])
  invoice      Invoice?  @relation(fields: [invoiceId], references: [id])

  @@index([companyId, promisedDate])
  @@index([customerId])
  @@index([invoiceId])
  @@map("cartera_payment_promises")
}

model CarteraCollectionFollowUp {
  id             String    @id
  companyId      String
  customerId     String
  invoiceId      String?
  activityType   String
  outcome        String
  nextActionDate DateTime?
  nextAction     String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  company        Company   @relation(fields: [companyId], references: [id])
  createdBy      User      @relation("CarteraCollectionFollowUpCreatedBy", fields: [createdById], references: [id])
  customer       Customer  @relation(fields: [customerId], references: [id])
  invoice        Invoice?  @relation(fields: [invoiceId], references: [id])

  @@index([companyId, createdAt])
  @@index([customerId])
  @@index([invoiceId])
  @@map("cartera_collection_followups")
}

model CarteraAdjustment {
  id              String          @id
  companyId       String
  customerId      String
  invoiceId       String?
  receiptId       String?
  sourceInvoiceId String?
  type            String
  status          String          @default("PENDING_APPROVAL")
  amount          Decimal         @db.Decimal(12, 2)
  reason          String
  notes           String?
  requestedById   String
  approvedById    String?
  approvedAt      DateTime?
  appliedAt       DateTime?
  rejectedAt      DateTime?
  rejectedReason  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now()) @updatedAt
  approvedBy      User?           @relation("CarteraAdjustmentApprovedBy", fields: [approvedById], references: [id])
  company         Company         @relation(fields: [companyId], references: [id])
  customer        Customer        @relation(fields: [customerId], references: [id])
  invoice         Invoice?        @relation("CarteraAdjustmentInvoice", fields: [invoiceId], references: [id])
  receipt         CarteraReceipt? @relation(fields: [receiptId], references: [id])
  requestedBy     User            @relation("CarteraAdjustmentRequestedBy", fields: [requestedById], references: [id])
  sourceInvoice   Invoice?        @relation("CarteraAdjustmentSourceInvoice", fields: [sourceInvoiceId], references: [id])

  @@index([companyId, createdAt])
  @@index([customerId])
  @@index([invoiceId])
  @@index([receiptId])
  @@index([status, type])
  @@map("cartera_adjustments")
}

model CarteraBankMovement {
  id              String          @id
  companyId       String
  bankCode        String?
  accountNumber   String?
  movementDate    DateTime
  reference       String?
  description     String?
  amount          Decimal         @db.Decimal(12, 2)
  status          String          @default("UNRECONCILED")
  matchedReceiptId String?
  reconciledById  String?
  reconciledAt    DateTime?
  importedById    String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now()) @updatedAt
  company         Company         @relation(fields: [companyId], references: [id])
  importedBy      User            @relation("CarteraBankMovementImportedBy", fields: [importedById], references: [id])
  matchedReceipt  CarteraReceipt? @relation(fields: [matchedReceiptId], references: [id])
  reconciledBy    User?           @relation("CarteraBankMovementReconciledBy", fields: [reconciledById], references: [id])

  @@index([companyId, movementDate])
  @@index([status])
  @@index([matchedReceiptId])
  @@map("cartera_bank_movements")
}

model Integration {
  id         String            @id @default(uuid())
  companyId  String
  type       IntegrationType
  name       String
  config     Json
  isActive   Boolean           @default(true)
  lastSyncAt DateTime?
  status     IntegrationStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  company    Company           @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("integrations")
}

model UsageTracking {
  id        String   @id @default(uuid())
  companyId String
  metric    String
  value     Int      @default(0)
  period    String
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, metric, period])
  @@index([companyId, period])
  @@map("usage_tracking")
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String?
  userId     String?
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  company    Company? @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

model ImportJob {
  id            String        @id @default(uuid())
  companyId     String
  userId        String
  type          String        @default("PRODUCTS")
  status        ImportStatus  @default(PENDING)
  fileName      String
  fileUrl       String
  totalRows     Int           @default(0)
  processedRows Int           @default(0)
  successRows   Int           @default(0)
  errorRows     Int           @default(0)
  reportUrl     String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  errors        ImportError[]
  company       Company       @relation(fields: [companyId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("import_jobs")
}

model ImportError {
  id          String    @id @default(uuid())
  importJobId String
  rowNumber   Int
  field       String?
  value       String?
  message     String
  rawData     Json?
  createdAt   DateTime  @default(now())
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@map("import_errors")
}

model Parameter {
  id        String   @id @default(uuid())
  category  String
  value     String
  label     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("parameters")
}

model Country {
  id          String       @id @default(uuid())
  code        String       @unique
  name        String
  isActive    Boolean      @default(true)
  departments Department[]

  @@index([code])
  @@map("countries")
}

model Department {
  id             String         @id @default(uuid())
  code           String         @unique
  name           String
  countryCode    String         @default("CO")
  isActive       Boolean        @default(true)
  country        Country        @relation(fields: [countryCode], references: [code])
  municipalities Municipality[]

  @@index([code])
  @@index([countryCode])
  @@map("departments")
}

model Municipality {
  id             String     @id @default(uuid())
  code           String     @unique
  name           String
  departmentCode String
  isActive       Boolean    @default(true)
  department     Department @relation(fields: [departmentCode], references: [code])

  @@index([code])
  @@index([departmentCode])
  @@map("municipalities")
}

model Bank {
  id        String      @id @default(uuid())
  code      String      @unique
  name      String
  isActive  Boolean     @default(true)
  employees employees[]

  @@index([code])
  @@map("banks")
}

model employees {
  id              String            @id @default(uuid())
  companyId       String
  documentType    String            @default("CC")
  documentNumber  String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  position        String
  baseSalary      Decimal           @db.Decimal(12, 2)
  contractType    String            @default("INDEFINITE")
  hireDate        DateTime
  city            String?
  bankAccount     String?
  bankName        String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  bankCode        String?
  cityCode        String?
  country         String            @default("CO")
  departmentCode  String?
  branchId        String?
  bank            Bank?             @relation(fields: [bankCode], references: [code])
  branch          Branch?           @relation("EmployeeBranch", fields: [branchId], references: [id])
  companies       Company           @relation(fields: [companyId], references: [id])
  payroll_records payroll_records[]

  @@unique([companyId, documentNumber])
  @@index([companyId])
  @@index([branchId])
}

model payroll_records {
  id                 String            @id @default(uuid())
  companyId          String
  employeeId         String
  period             String
  payDate            DateTime
  status             String            @default("DRAFT")
  cune               String?           @unique
  cuneHash           String?
  cuneInput          String?
  payrollType        PayrollType       @default(NOMINA_ELECTRONICA)
  payrollNumber      String?
  xmlSigned          String?
  xmlUrl             String?
  pdfUrl             String?
  dianZipKey         String?
  dianStatus         String?
  dianStatusCode     String?
  dianStatusMsg      String?
  dianErrors         String?
  dianAttempts       Int               @default(0)
  cuneRef            String?
  payrollNumberRef   String?
  fechaGenRef        String?
  tipoAjuste         String?
  originalNieId      String?
  predecessorId      String?
  isAnulado          Boolean           @default(false)
  submittedAt        DateTime?
  baseSalary         Decimal           @db.Decimal(12, 2)
  daysWorked         Int               @default(30)
  overtimeHours      Decimal           @default(0) @db.Decimal(8, 2)
  bonuses            Decimal           @default(0) @db.Decimal(12, 2)
  commissions        Decimal           @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal           @default(0) @db.Decimal(12, 2)
  vacationPay        Decimal           @default(0) @db.Decimal(12, 2)
  healthEmployee     Decimal           @default(0) @db.Decimal(12, 2)
  pensionEmployee    Decimal           @default(0) @db.Decimal(12, 2)
  sickLeave          Decimal           @default(0) @db.Decimal(12, 2)
  loans              Decimal           @default(0) @db.Decimal(12, 2)
  otherDeductions    Decimal           @default(0) @db.Decimal(12, 2)
  healthEmployer     Decimal           @default(0) @db.Decimal(12, 2)
  pensionEmployer    Decimal           @default(0) @db.Decimal(12, 2)
  arl                Decimal           @default(0) @db.Decimal(12, 2)
  compensationFund   Decimal           @default(0) @db.Decimal(12, 2)
  totalEarnings      Decimal           @db.Decimal(12, 2)
  totalDeductions    Decimal           @db.Decimal(12, 2)
  netPay             Decimal           @db.Decimal(12, 2)
  totalEmployerCost  Decimal           @db.Decimal(12, 2)
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  branchId           String?
  invoiceId          String?           @unique
  branch             Branch?           @relation("PayrollBranch", fields: [branchId], references: [id])
  companies          Company           @relation(fields: [companyId], references: [id])
  employees          employees         @relation(fields: [employeeId], references: [id])
  invoice            Invoice?          @relation("PayrollInvoice", fields: [invoiceId], references: [id])
  originalNie        payroll_records?  @relation("NieChain", fields: [originalNieId], references: [id])
  adjustments        payroll_records[] @relation("NieChain")
  predecessor        payroll_records?  @relation("NiaeChain", fields: [predecessorId], references: [id])
  successors         payroll_records[] @relation("NiaeChain")

  @@index([companyId, employeeId, period, payrollType])
  @@index([companyId, employeeId, payrollType])
  @@index([companyId, employeeId, originalNieId])
  @@index([branchId])
}

model DianXmlTemplate {
  id            String           @id @default(uuid())
  documentType  DianDocumentType
  version       String           @default("V1.0:2021")
  name          String
  description   String?
  xmlTemplate   String
  xsdSchemaUrl  String?
  namespace     String?
  rootElement   String?
  hashAlgorithm String?
  hashFields    String?
  isActive      Boolean          @default(true)
  isCurrent     Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdBy     String?

  @@unique([documentType, version])
  @@index([documentType, isActive])
  @@map("dian_xml_templates")
}

model PosSession {
  id                String            @id @default(uuid())
  companyId         String
  userId            String
  status            PosSessionStatus  @default(OPEN)
  openedAt          DateTime          @default(now())
  closedAt          DateTime?
  initialCash       Decimal           @default(0) @db.Decimal(12, 2)
  finalCash         Decimal?          @db.Decimal(12, 2)
  expectedCash      Decimal?          @db.Decimal(12, 2)
  cashDifference    Decimal?          @db.Decimal(12, 2)
  totalSales        Decimal           @default(0) @db.Decimal(12, 2)
  totalTransactions Int               @default(0)
  notes             String?
  branchId          String?
  cashMovements     PosCashMovement[]
  sales             PosSale[]
  branch            Branch?           @relation(fields: [branchId], references: [id])
  company           Company           @relation(fields: [companyId], references: [id])
  user              User              @relation(fields: [userId], references: [id])

  @@index([companyId, status])
  @@index([companyId, openedAt])
  @@index([branchId])
  @@map("pos_sessions")
}

model PosSale {
  id              String         @id @default(uuid())
  companyId       String
  sessionId       String
  customerId      String?
  saleNumber      String
  subtotal        Decimal        @db.Decimal(12, 2)
  taxAmount       Decimal        @db.Decimal(12, 2)
  discountAmount  Decimal        @default(0) @db.Decimal(12, 2)
  total           Decimal        @db.Decimal(12, 2)
  paymentMethod   PaymentMethod  @default(CASH)
  amountPaid      Decimal        @db.Decimal(12, 2)
  change          Decimal        @default(0) @db.Decimal(12, 2)
  status          PosSaleStatus  @default(COMPLETED)
  invoiceId       String?        @unique
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  branchId        String?
  advanceAmount   Decimal        @default(0) @db.Decimal(12, 2)
  deliveryStatus  DeliveryStatus @default(DELIVERED)
  remainingAmount Decimal        @default(0) @db.Decimal(12, 2)
  items           PosSaleItem[]
  branch          Branch?        @relation(fields: [branchId], references: [id])
  company         Company        @relation(fields: [companyId], references: [id])
  customer        Customer?      @relation(fields: [customerId], references: [id])
  invoice         Invoice?       @relation("PosSaleInvoice", fields: [invoiceId], references: [id])
  session         PosSession     @relation(fields: [sessionId], references: [id])

  @@unique([companyId, saleNumber])
  @@index([companyId, createdAt])
  @@index([sessionId])
  @@index([branchId])
  @@map("pos_sales")
}

model PosSaleItem {
  id          String   @id @default(uuid())
  saleId      String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  taxAmount   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  product     Product? @relation(fields: [productId], references: [id])
  sale        PosSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("pos_sale_items")
}

model PosCashMovement {
  id        String           @id @default(uuid())
  companyId String
  sessionId String
  userId    String
  type      CashMovementType
  amount    Decimal          @db.Decimal(12, 2)
  reason    String
  createdAt DateTime         @default(now())
  company   Company          @relation(fields: [companyId], references: [id])
  session   PosSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([companyId, createdAt])
  @@map("pos_cash_movements")
}

model DianTestSet {
  id           String                @id @default(uuid())
  companyId    String
  type         DianTestSetType
  status       DianTestSetStatus     @default(PENDING)
  totalDocs    Int
  sentDocs     Int                   @default(0)
  acceptedDocs Int                   @default(0)
  rejectedDocs Int                   @default(0)
  errorDocs    Int                   @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  documents    DianTestSetDocument[]
  company      Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("dian_test_sets")
}

model DianTestSetDocument {
  id             String      @id @default(uuid())
  testSetId      String
  sequence       Int
  docType        String
  invoiceId      String?
  payrollId      String?
  status         String      @default("PENDING")
  dianZipKey     String?
  dianStatusCode String?
  dianStatusMsg  String?
  errorMsg       String?
  sentAt         DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  testSet        DianTestSet @relation(fields: [testSetId], references: [id], onDelete: Cascade)

  @@map("dian_test_set_documents")
}

model AccountingAccount {
  id        String              @id @default(uuid())
  companyId String
  code      String
  name      String
  level     Int
  parentId  String?
  nature    AccountNature       @default(DEBIT)
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  company   Company             @relation(fields: [companyId], references: [id])
  parent    AccountingAccount?  @relation("AccountTree", fields: [parentId], references: [id])
  children  AccountingAccount[] @relation("AccountTree")
  lines     JournalEntryLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, level])
  @@map("accounting_accounts")
}

model AccountingPeriod {
  id        String                 @id @default(uuid())
  companyId String
  name      String
  year      Int
  month     Int
  startDate DateTime
  endDate   DateTime
  status    AccountingPeriodStatus @default(OPEN)
  isLocked  Boolean                @default(false)
  closedAt  DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  company   Company                @relation(fields: [companyId], references: [id])

  @@unique([companyId, year, month])
  @@index([companyId])
  @@index([companyId, status])
  @@map("accounting_periods")
}

model JournalEntry {
  id          String             @id @default(uuid())
  companyId   String
  number      String
  date        DateTime
  description String
  reference   String?
  sourceType  JournalSourceType  @default(MANUAL)
  sourceId    String?
  status      JournalEntryStatus @default(DRAFT)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  company     Company            @relation(fields: [companyId], references: [id])
  lines       JournalEntryLine[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, date])
  @@index([companyId, status])
  @@map("journal_entries")
}

model JournalEntryLine {
  id          String            @id @default(uuid())
  entryId     String
  accountId   String
  description String?
  debit       Decimal           @default(0) @db.Decimal(12, 2)
  credit      Decimal           @default(0) @db.Decimal(12, 2)
  position    Int
  account     AccountingAccount @relation(fields: [accountId], references: [id])
  entry       JournalEntry      @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  companyId      String
  number         String
  status         PurchaseOrderStatus @default(DRAFT)
  issueDate      DateTime
  dueDate        DateTime?
  subtotal       Decimal             @db.Decimal(12, 2)
  taxAmount      Decimal             @db.Decimal(12, 2)
  discountAmount Decimal             @default(0) @db.Decimal(12, 2)
  total          Decimal             @db.Decimal(12, 2)
  notes          String?
  currency       String              @default("COP")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  customerId     String
  items          PurchaseOrderItem[]
  company        Company             @relation(fields: [companyId], references: [id])
  customer       Customer            @relation(fields: [customerId], references: [id])

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          String        @id @default(uuid())
  orderId     String
  productId   String?
  description String
  quantity    Decimal       @db.Decimal(12, 4)
  unitPrice   Decimal       @db.Decimal(12, 2)
  taxRate     Decimal       @db.Decimal(5, 2)
  taxAmount   Decimal       @db.Decimal(12, 2)
  discount    Decimal       @default(0) @db.Decimal(5, 2)
  total       Decimal       @db.Decimal(12, 2)
  position    Int
  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?      @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("purchase_order_items")
}

model Quote {
  id             String      @id @default(uuid())
  companyId      String
  customerId     String
  number         String
  status         QuoteStatus @default(DRAFT)
  issueDate      DateTime
  expiresAt      DateTime?
  subtotal       Decimal     @db.Decimal(12, 2)
  taxAmount      Decimal     @db.Decimal(12, 2)
  discountAmount Decimal     @default(0) @db.Decimal(12, 2)
  total          Decimal     @db.Decimal(12, 2)
  notes          String?
  terms          String?
  invoiceId      String?     @unique
  currency       String      @default("COP")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  items          QuoteItem[]
  company        Company     @relation(fields: [companyId], references: [id])
  customer       Customer    @relation(fields: [customerId], references: [id])
  invoice        Invoice?    @relation("QuoteInvoice", fields: [invoiceId], references: [id])

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(uuid())
  quoteId     String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  taxAmount   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  total       Decimal  @db.Decimal(12, 2)
  position    Int
  product     Product? @relation(fields: [productId], references: [id])
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum TaxType {
  IVA
  INC
  ICA
  NONE
}

enum DocumentType {
  NIT
  CC
  CE
  PASSPORT
  TI
}

enum InvoiceType {
  VENTA
  NOTA_CREDITO
  NOTA_DEBITO
  SOPORTE_ADQUISICION
}

enum InvoiceStatus {
  DRAFT
  SENT_DIAN
  ACCEPTED_DIAN
  REJECTED_DIAN
  PAID
  CANCELLED
  OVERDUE
}

enum IntegrationType {
  DIAN
  NOMINA
  CONTABILIDAD
  BANCOS
  ECOMMERCE
  CUSTOM
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  ERROR
  SUSPENDED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
  CANCELLED
}

enum PayrollType {
  NOMINA_ELECTRONICA
  NOMINA_AJUSTE
}

enum DianDocumentType {
  FACTURA_VENTA
  NOTA_CREDITO
  NOTA_DEBITO
  FACTURA_EXPORTACION
  DOCUMENTO_SOPORTE
  NOTA_AJUSTE_SOPORTE
  NOMINA_INDIVIDUAL
  NOMINA_INDIVIDUAL_AJUSTE
}

enum PosSessionStatus {
  OPEN
  CLOSED
}

enum PosSaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
  ADVANCE
}

enum DeliveryStatus {
  PENDING
  DELIVERED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}

enum CashMovementType {
  IN
  OUT
}

enum DianTestSetType {
  FACTURACION
  NOMINA
}

enum DianTestSetStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PARTIAL
  FAILED
}

enum AccountNature {
  DEBIT
  CREDIT
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum JournalSourceType {
  MANUAL
  INVOICE
  PURCHASE
  PAYROLL
  ADJUSTMENT
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED
  PARTIAL
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}
