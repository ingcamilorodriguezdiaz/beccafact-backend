// BeccaFact - Prisma Schema
// Multi-tenant SaaS ERP for Colombia

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// PLANS & FEATURES
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id          String   @id @default(uuid())
  name        String   @unique // BASIC | EMPRESARIAL | CORPORATIVO
  displayName String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("COP")
  isActive    Boolean  @default(true)
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  features      PlanFeature[]
  subscriptions Subscription[]

  @@map("plans")
}

model PlanFeature {
  id     String @id @default(uuid())
  planId String
  key    String // max_documents_per_month | max_products | max_integrations | storage_months | etc.
  value  String // "300" | "unlimited" | "true" | "false"
  label  String?

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@map("plan_features")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPANIES
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id             String        @id @default(uuid())
  name           String
  nit            String        @unique
  razonSocial    String
  email          String
  phone          String?
  address        String?
  city           String?
  department     String?
  cityCode       String?
  departmentCode String?
  country        String        @default("CO")
  status         CompanyStatus @default(ACTIVE)
  dianTestMode       Boolean           @default(true)
  dianSoftwareId     String?
  dianSoftwarePin    String?
  dianTestSetId      String?
  dianClaveTecnica   String?
  dianResolucion     String?
  dianPrefijo        String?
  dianRangoDesde     Int?
  dianRangoHasta     Int?
  dianFechaDesde     String?
  dianFechaHasta     String?
  dianCertificate    String?
  dianCertificateKey String?
  // ── DIAN Nómina Electrónica — credenciales propias por empresa ───────────
  nominaSoftwareId  String?   // Software ID registrado en DIAN para nómina electrónica
  nominaSoftwarePin String?   // PIN numérico del software de nómina
  nominaTestSetId   String?   // TestSetId UUID del ambiente de habilitación nómina
  logoUrl        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  users          User[]
  subscriptions  Subscription[]
  products       Product[]
  categories     Category[]
  invoices       Invoice[]
  customers      Customer[]
  integrations   Integration[]
  usageTracking  UsageTracking[]
  auditLogs      AuditLog[]
  importJobs     ImportJob[]
  employees      employees[]
  payroll_records    payroll_records[]
  pos_sessions   PosSession[]
  pos_sales      PosSale[]
  @@index([status])
  @@index([nit])
  @@map("companies")
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

// ─────────────────────────────────────────────────────────────────────────────
// SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Subscription {
  id               String             @id @default(uuid())
  companyId        String
  planId           String
  status           SubscriptionStatus @default(ACTIVE)
  startDate        DateTime
  endDate          DateTime?
  trialEndsAt      DateTime?
  customLimits     Json?              // Override per-company limits
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
  EXPIRED
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & ROLES
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  avatar         String?
  isActive       Boolean   @default(true)
  isSuperAdmin   Boolean   @default(false)
  hasSeenTour    Boolean   @default(false)
  companyId      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  lastLoginAt    DateTime?
  refreshToken   String?   @db.Text

  company        Company?         @relation(fields: [companyId], references: [id])
  roles          UserRole[]
  auditLogs      AuditLog[]
  importJobs     ImportJob[]
  pos_sessions   PosSession[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // SUPER_ADMIN | ADMIN | MANAGER | OPERATOR | VIEWER
  displayName String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model RolePermission {
  id         String @id @default(uuid())
  roleId     String
  resource   String // invoices | products | customers | reports | etc.
  action     String // create | read | update | delete | export | import

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTS & CATEGORIES
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company  Company    @relation(fields: [companyId], references: [id])
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("categories")
}

model Product {
  id           String        @id @default(uuid())
  companyId    String
  categoryId   String?
  sku          String
  name         String
  description  String?       @db.Text
  price        Decimal       @db.Decimal(12, 2)
  cost         Decimal       @default(0) @db.Decimal(12, 2)
  stock        Int           @default(0)
  minStock     Int           @default(0)
  unit         String        @default("UND")
  taxRate      Decimal       @default(19) @db.Decimal(5, 2)
  taxType      TaxType       @default(IVA)
  unspscCode   String?
  status       ProductStatus @default(ACTIVE)
  imageUrl     String?
  barcode      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  company      Company       @relation(fields: [companyId], references: [id])
  category     Category?     @relation(fields: [categoryId], references: [id])
  invoiceItems InvoiceItem[]
  posSaleItems PosSaleItem[]

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([companyId, status])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum TaxType {
  IVA
  INC
  ICA
  NONE
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id             String       @id @default(uuid())
  companyId      String
  documentType   DocumentType @default(NIT)
  documentNumber String
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  department     String?
  cityCode       String?
  departmentCode String?
  country        String       @default("CO")
  isActive       Boolean      @default(true)
  creditLimit    Decimal?     @db.Decimal(12, 2)
  creditDays     Int?
  notes          String?      @db.Text
  taxLevelCode   String? 
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  company   Company    @relation(fields: [companyId], references: [id])
  invoices  Invoice[]
  pos_sales PosSale[]

  @@unique([companyId, documentType, documentNumber])
  @@index([companyId])
  @@map("customers")
}

enum DocumentType {
  NIT
  CC
  CE
  PASSPORT
  TI
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(uuid())
  companyId       String
  customerId      String
  invoiceNumber   String
  prefix          String        @default("FV")
  type            InvoiceType   @default(VENTA)
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime
  dueDate         DateTime?
  subtotal        Decimal       @db.Decimal(12, 2)
  taxAmount       Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  notes           String?       @db.Text
  dianCufe        String?       @unique
  dianQrCode      String?       @db.Text
  dianStatus      String?                        // raw DIAN status code stored for reference
  dianStatusCode  String?                        // 00=aceptado, 99=rechazado, 66=no encontrado
  dianStatusMsg   String?       @db.Text         // statusMessage / statusDescription from DIAN
  dianErrors      String?       @db.Text         // JSON array: ErrorMessageList from GetStatusZip
  dianZipKey      String?                        // trackId returned by SendTestSetAsync/SendBillAsync
  dianXmlBase64   String?       @db.Text         // ApplicationResponse XML (base64) from DIAN
  dianSentAt      DateTime?
  dianResponseAt  DateTime?
  dianAttempts    Int           @default(0)      // number of send attempts
  // ── Nota Crédito / Nota Débito — referencia a factura original ───────────
  originalInvoiceId     String?                        // FK: nota referencia esta factura de origen
  discrepancyReasonCode String?                        // Código DIAN: 1=devol.parcial 2=anulación 3=rebaja 4=ajuste calidad 5=rescisión 6=otros
  discrepancyReason     String?   @db.Text             // Descripción libre del motivo del ajuste
  dianCude              String?   @unique               // CUDE para notas crédito/débito (distinto del CUFE de facturas)
  xmlContent      String?
  xmlSigned       String?       @db.Text         // signed UBL 2.1 XML sent to DIAN
  pdfUrl          String?
  xmlUrl          String?
  currency        String        @default("COP")
  exchangeRate    Decimal       @default(1) @db.Decimal(12, 4)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  company  Company       @relation(fields: [companyId], references: [id])
  customer Customer      @relation(fields: [customerId], references: [id])
  items    InvoiceItem[]
  // Auto-relación notas (NC / ND referencia factura original)
  originalInvoice      Invoice?   @relation("InvoiceNotes", fields: [originalInvoiceId], references: [id])
  creditDebitNotes     Invoice[]  @relation("InvoiceNotes")

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@index([originalInvoiceId])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(12, 4)
  unitPrice   Decimal @db.Decimal(12, 2)
  taxRate     Decimal @db.Decimal(5, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  total       Decimal @db.Decimal(12, 2)
  position    Int

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

enum InvoiceType {
  VENTA
  NOTA_CREDITO
  NOTA_DEBITO
  SOPORTE_ADQUISICION
}

enum InvoiceStatus {
  DRAFT
  SENT_DIAN
  ACCEPTED_DIAN
  REJECTED_DIAN
  PAID
  CANCELLED
  OVERDUE
}

// ─────────────────────────────────────────────────────────────────────────────
// INTEGRATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Integration {
  id          String            @id @default(uuid())
  companyId   String
  type        IntegrationType
  name        String
  config      Json
  isActive    Boolean           @default(true)
  lastSyncAt  DateTime?
  status      IntegrationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("integrations")
}

enum IntegrationType {
  DIAN
  NOMINA
  CONTABILIDAD
  BANCOS
  ECOMMERCE
  CUSTOM
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  ERROR
  SUSPENDED
}

// ─────────────────────────────────────────────────────────────────────────────
// USAGE TRACKING
// ─────────────────────────────────────────────────────────────────────────────

model UsageTracking {
  id          String   @id @default(uuid())
  companyId   String
  metric      String   // documents_issued | products_created | storage_used
  value       Int      @default(0)
  period      String   // YYYY-MM
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, metric, period])
  @@index([companyId, period])
  @@map("usage_tracking")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String?
  userId     String?
  action     String   // CREATE | UPDATE | DELETE | LOGIN | EXPORT | etc.
  resource   String   // invoice | product | user | etc.
  resourceId String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// IMPORT JOBS
// ─────────────────────────────────────────────────────────────────────────────

model ImportJob {
  id           String      @id @default(uuid())
  companyId    String
  userId       String
  type         String      @default("PRODUCTS")
  status       ImportStatus @default(PENDING)
  fileName     String
  fileUrl      String
  totalRows    Int         @default(0)
  processedRows Int        @default(0)
  successRows  Int         @default(0)
  errorRows    Int         @default(0)
  reportUrl    String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company Company       @relation(fields: [companyId], references: [id])
  user    User          @relation(fields: [userId], references: [id])
  errors  ImportError[]

  @@index([companyId])
  @@index([status])
  @@map("import_jobs")
}

model ImportError {
  id         String   @id @default(uuid())
  importJobId String
  rowNumber  Int
  field      String?
  value      String?
  message    String
  rawData    Json?
  createdAt  DateTime @default(now())

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@map("import_errors")
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  ERROR
  CANCELLED
}




// ─────────────────────────────────────────────────────────────────────────────
// PARAMETERS
// ─────────────────────────────────────────────────────────────────────────────

model Parameter {
  id        String   @id @default(uuid())
  category     String
  value     String
  label     String?
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("parameters")
}

// ─────────────────────────────────────────────────────────────────────────────
// GEOGRAPHIC LOCATION
// ─────────────────────────────────────────────────────────────────────────────

model Country {
  id          String   @id @default(uuid())
  code        String   @unique // ISO 3166-1 alpha-2: CO, US, MX ...
  name        String
  isActive    Boolean  @default(true)

  departments Department[]

  @@index([code])
  @@map("countries")
}

model Department {
  id          String   @id @default(uuid())
  code        String   @unique // DIVIPOLA 2 dígitos: 05, 11, 25 ...
  name        String
  countryCode String   @default("CO")
  isActive    Boolean  @default(true)

  country       Country      @relation(fields: [countryCode], references: [code])
  municipalities Municipality[]

  @@index([code])
  @@index([countryCode])
  @@map("departments")
}

model Municipality {
  id             String   @id @default(uuid())
  code           String   @unique // DIVIPOLA 5 dígitos: 05001, 11001, 25473 ...
  name           String
  departmentCode String   // primeros 2 dígitos del código municipal
  isActive       Boolean  @default(true)

  department Department @relation(fields: [departmentCode], references: [code])

  @@index([code])
  @@index([departmentCode])
  @@map("municipalities")
}

// ─────────────────────────────────────────────────────────────────────────────
// BANKS — Catálogo global de bancos colombianos (códigos ACH/DIAN)
// ─────────────────────────────────────────────────────────────────────────────

model Bank {
  id       String  @id @default(uuid())
  code     String  @unique // Código ACH 3 dígitos: "007", "051", etc.
  name     String
  isActive Boolean @default(true)

  employees employees[]

  @@index([code])
  @@map("banks")
}

model employees {
  id              String   @id @default(uuid())
  companyId       String
  documentType    String            @default("CC")
  documentNumber  String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  position        String
  baseSalary      Decimal           @db.Decimal(12, 2)
  contractType    String            @default("INDEFINITE")
  hireDate        DateTime
  city            String?
  cityCode        String?           // DIVIPOLA 5 dígitos: 11001, 05001…
  departmentCode  String?           // DIVIPOLA 2 dígitos: 11, 05…
  country         String            @default("CO")
  bankAccount     String?
  bankName        String?
  bankCode        String?           // Código ACH del banco (FK a Bank.code)
  bank            Bank?             @relation(fields: [bankCode], references: [code])
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  companies       Company           @relation(fields: [companyId], references: [id])
  payroll_records payroll_records[]

  @@unique([companyId, documentNumber])
  @@index([companyId])
}

model payroll_records {
  id        String   @id @default(uuid())

  companyId  String
  employeeId String

  period  String
  payDate DateTime

  status String @default("DRAFT")

  // DIAN
  cune        String? @unique
  cuneHash    String?
  cuneInput   String?

  payrollType   PayrollType @default(NOMINA_ELECTRONICA)
  payrollNumber String?

  xmlSigned String? @db.Text
  xmlUrl    String?
  pdfUrl    String?

  dianZipKey   String?
  dianStatus   String?
  dianStatusCode  String?
  dianStatusMsg   String?
  dianErrors   String?
  dianAttempts Int      @default(0)
  cuneRef          String?   // CUNE del documento predecesor (NIE o NIAE)
  payrollNumberRef String?   // Número del documento predecesor
  fechaGenRef      String?   // Fecha de emisión del predecesor (FechaGenPred)
  tipoAjuste       String?   // 'Reemplazar' | 'Eliminar'

  // Cadena de ajustes:
  // · originalNieId: apunta siempre al NIE raíz (primer documento del período)
  // · predecessorId: apunta al documento inmediatamente anterior en la cadena
  //   (NIE → NIAE-R → NIAE-R → NIAE-E)
  // · isAnulado: true cuando sobre este período ya existe un Eliminar ACCEPTED;
  //   bloquea la creación de nuevos ajustes
  originalNieId    String?   // FK al NIE raíz del período
  predecessorId    String?   // FK al doc predecesor directo en la cadena
  isAnulado        Boolean   @default(false)  // período anulado por NIAE-Eliminar

  submittedAt DateTime?

  // DEVENGADOS
  baseSalary         Decimal   @db.Decimal(12, 2)
  daysWorked         Int       @default(30)
  overtimeHours      Decimal   @default(0) @db.Decimal(8, 2)
  bonuses            Decimal   @default(0) @db.Decimal(12, 2)
  commissions        Decimal   @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal   @default(0) @db.Decimal(12, 2)
  vacationPay        Decimal   @default(0) @db.Decimal(12, 2)

  // DEDUCCIONES
  healthEmployee  Decimal @default(0) @db.Decimal(12, 2)
  pensionEmployee Decimal @default(0) @db.Decimal(12, 2)
  sickLeave       Decimal @default(0) @db.Decimal(12, 2)
  loans           Decimal @default(0) @db.Decimal(12, 2)
  otherDeductions Decimal @default(0) @db.Decimal(12, 2)

  // APORTES EMPLEADOR
  healthEmployer   Decimal @default(0) @db.Decimal(12, 2)
  pensionEmployer  Decimal @default(0) @db.Decimal(12, 2)
  arl              Decimal @default(0) @db.Decimal(12, 2)
  compensationFund Decimal @default(0) @db.Decimal(12, 2)

  // TOTALES
  totalEarnings     Decimal @db.Decimal(12, 2)
  totalDeductions   Decimal @db.Decimal(12, 2)
  netPay            Decimal @db.Decimal(12, 2)
  totalEmployerCost Decimal @db.Decimal(12, 2)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies Company   @relation(fields: [companyId], references: [id])
  employees employees @relation(fields: [employeeId], references: [id])

  // Auto-referencias para la cadena NIE → NIAE → NIAE
  originalNie  payroll_records?  @relation("NieChain",  fields: [originalNieId],  references: [id])
  adjustments  payroll_records[] @relation("NieChain")
  predecessor  payroll_records?  @relation("NiaeChain", fields: [predecessorId],  references: [id])
  successors   payroll_records[] @relation("NiaeChain")

  // El NIE (NOMINA_ELECTRONICA) es único por (companyId, employeeId, period) — validado en el servicio.
  // La NIAE (NOMINA_AJUSTE) permite MÚLTIPLES registros por período (Reemplazar encadenados + 1 Eliminar).
  // Por eso se usa @@index en lugar de @@unique: el unique rompería el segundo Reemplazar.
  @@index([companyId, employeeId, period, payrollType])
  @@index([companyId, employeeId, payrollType])
  @@index([companyId, employeeId, originalNieId])   // buscar cadena por NIE raíz
}

enum PayrollType {
  NOMINA_ELECTRONICA
  NOMINA_AJUSTE
}


// ─────────────────────────────────────────────────────────────────────────────
// DIAN XML TEMPLATES — Plantillas de estructura XML por tipo de documento
// ─────────────────────────────────────────────────────────────────────────────

model DianXmlTemplate {
  id           String           @id @default(uuid())

  documentType DianDocumentType // Tipo de documento
  version      String           @default("V1.0:2021")
  name         String           // "Factura Electrónica de Venta"
  description  String?          @db.Text

  // XML base con placeholders {{campo}} para campos dinámicos
  xmlTemplate  String           @db.Text

  // Metadatos del esquema
  xsdSchemaUrl String?          // URL XSD oficial DIAN
  namespace    String?          // dian:gov:co:facturaelectronica:NominaIndividual
  rootElement  String?          // NominaIndividual | Invoice | CreditNote

  // Hash — describe los campos y orden para calcular CUFE/CUNE
  hashAlgorithm  String?        // SHA384 | SHA256
  hashFields     String?        @db.Text  // "Numero+FechaGen+HoraGen+..."

  // Control
  isActive   Boolean  @default(true)
  isCurrent  Boolean  @default(true) // Solo uno activo por documentType+version
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?  // userId

  @@unique([documentType, version])
  @@index([documentType, isActive])
  @@map("dian_xml_templates")
}

enum DianDocumentType {
  // Facturación Electrónica
  FACTURA_VENTA            // Código 01
  NOTA_CREDITO             // Código 91
  NOTA_DEBITO              // Código 92
  FACTURA_EXPORTACION      // Código 02
  DOCUMENTO_SOPORTE        // Código 05
  NOTA_AJUSTE_SOPORTE      // Código 95

  // Nómina Electrónica
  NOMINA_INDIVIDUAL        // TipoXML 102
  NOMINA_INDIVIDUAL_AJUSTE // TipoXML 103
}

// ─────────────────────────────────────────────────────────────────────────────
// POS — Point of Sale
// ─────────────────────────────────────────────────────────────────────────────

model PosSession {
  id             String           @id @default(uuid())
  companyId      String
  userId         String
  status         PosSessionStatus @default(OPEN)
  openedAt       DateTime         @default(now())
  closedAt       DateTime?
  initialCash    Decimal          @default(0) @db.Decimal(12, 2)
  finalCash      Decimal?         @db.Decimal(12, 2)
  expectedCash   Decimal?         @db.Decimal(12, 2)
  cashDifference Decimal?         @db.Decimal(12, 2)
  totalSales     Decimal          @default(0) @db.Decimal(12, 2)
  totalTransactions Int           @default(0)
  notes          String?

  company Company    @relation(fields: [companyId], references: [id])
  user    User       @relation(fields: [userId], references: [id])
  sales   PosSale[]

  @@index([companyId, status])
  @@index([companyId, openedAt])
  @@map("pos_sessions")
}

model PosSale {
  id             String        @id @default(uuid())
  companyId      String
  sessionId      String
  customerId     String?
  saleNumber     String
  subtotal       Decimal       @db.Decimal(12, 2)
  taxAmount      Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  paymentMethod  PaymentMethod @default(CASH)
  amountPaid     Decimal       @db.Decimal(12, 2)
  change         Decimal       @default(0) @db.Decimal(12, 2)
  status         PosSaleStatus @default(COMPLETED)
  invoiceId      String?       @unique
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  company  Company       @relation(fields: [companyId], references: [id])
  session  PosSession    @relation(fields: [sessionId], references: [id])
  customer Customer?     @relation(fields: [customerId], references: [id])
  items    PosSaleItem[]

  @@unique([companyId, saleNumber])
  @@index([companyId, createdAt])
  @@index([sessionId])
  @@map("pos_sales")
}

model PosSaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(12, 4)
  unitPrice   Decimal @db.Decimal(12, 2)
  taxRate     Decimal @db.Decimal(5, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  subtotal    Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  sale    PosSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@map("pos_sale_items")
}

enum PosSessionStatus {
  OPEN
  CLOSED
}

enum PosSaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}