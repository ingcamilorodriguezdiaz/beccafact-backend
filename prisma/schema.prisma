model Branch {
  id                           String                       @id @default(uuid())
  companyId                    String
  name                         String
  address                      String?
  city                         String?
  department                   String?
  phone                        String?
  email                        String?
  isMain                       Boolean                      @default(false)
  isActive                     Boolean                      @default(true)
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
  deletedAt                    DateTime?
  cityCode                     String?
  country                      String?                      @default("CO")
  departmentCode               String?
  company                      Company                      @relation(fields: [companyId], references: [id])
  deliveryNotes                DeliveryNote[]
  employees                    employees[]                  @relation("EmployeeBranch")
  invoice_accounting_profiles  InvoiceAccountingProfile[]
  invoiceDianProcessingJobs    InvoiceDianProcessingJob[]
  invoiceDocumentConfigs       InvoiceDocumentConfig[]
  invoiceExternalIntakes       InvoiceExternalIntake[]
  invoices                     Invoice[]
  journalEntryLines            JournalEntryLine[]
  payrollCalendars             PayrollCalendar[]
  payrollBatches               PayrollBatch[]
  payrollConcepts              PayrollConcept[]
  payrollContractHistory       PayrollContractHistory[]
  payrollEmploymentEvents      PayrollEmploymentEvent[]
  payrollDianProcessingJobs    PayrollDianProcessingJob[]
  payrollEnterpriseRules       PayrollEnterpriseRule[]
  payrollNovelties             PayrollNovelty[]
  payrollAccountingProfiles    PayrollAccountingProfile[]
  payrollPeriodControls        PayrollPeriodControl[]
  payrollPolicies              PayrollPolicy[]
  payrollProvisionRuns         PayrollProvisionRun[]
  payrollAccrualBalances       PayrollAccrualBalance[]
  payroll_records              payroll_records[]            @relation("PayrollBranch")
  payrollTypeConfigs           PayrollTypeConfig[]
  posBankReconciliationBatches PosBankReconciliationBatch[]
  posCombos                    PosCombo[]
  posConfigDeployments         PosConfigDeployment[]
  posCoupons                   PosCoupon[]
  posExternalOrders            PosExternalOrder[]
  posGovernanceRules           PosGovernanceRule[]
  posIntegrationTraces         PosIntegrationTrace[]
  posInventoryLocations        PosInventoryLocation[]
  posInventoryReservations     PosInventoryReservation[]
  posInventoryStocks           PosInventoryStock[]
  posInventoryTransferItems    PosInventoryTransferItem[]
  posInventoryTransfersFrom    PosInventoryTransfer[]       @relation("PosInventoryTransferFromBranch")
  posInventoryTransfersTo      PosInventoryTransfer[]       @relation("PosInventoryTransferToBranch")
  posLoyaltyCampaigns          PosLoyaltyCampaign[]
  posOperationalIncidents      PosOperationalIncident[]
  posPostSaleRequests          PosPostSaleRequest[]
  posPriceLists                PosPriceList[]
  posPromotions                PosPromotion[]
  posSales                     PosSale[]
  posSessions                  PosSession[]
  posShiftTemplates            PosShiftTemplate[]
  posGovernanceOverrides       PosSupervisorOverride[]
  posTerminals                 PosTerminal[]
  products                     Product[]
  salesOrders                  SalesOrder[]
  userBranches                 UserBranch[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, isActive])
  @@map("branches")
}

model UserBranch {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  companyId String
  createdAt DateTime @default(now())
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([companyId])
  @@map("user_branches")
}

model Subscription {
  id           String             @id @default(uuid())
  companyId    String
  planId       String
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?
  trialEndsAt  DateTime?
  customLimits Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  company      Company            @relation(fields: [companyId], references: [id])
  plan         Plan               @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

model User {
  id                                    String                        @id @default(uuid())
  email                                 String                        @unique
  password                              String
  firstName                             String
  lastName                              String
  phone                                 String?
  avatar                                String?
  isActive                              Boolean                       @default(true)
  isSuperAdmin                          Boolean                       @default(false)
  companyId                             String?
  createdAt                             DateTime                      @default(now())
  updatedAt                             DateTime                      @updatedAt
  deletedAt                             DateTime?
  lastLoginAt                           DateTime?
  refreshToken                          String?
  hasSeenTour                           Boolean                       @default(false)
  createdAccountPayablePayments         AccountPayablePayment[]       @relation("AccountPayablePaymentCreatedBy")
  auditLogs                             AuditLog[]
  approvedCarteraAdjustments            CarteraAdjustment[]           @relation("CarteraAdjustmentApprovedBy")
  requestedCarteraAdjustments           CarteraAdjustment[]           @relation("CarteraAdjustmentRequestedBy")
  importedCarteraBankMovements          CarteraBankMovement[]         @relation("CarteraBankMovementImportedBy")
  reconciledCarteraBankMovements        CarteraBankMovement[]         @relation("CarteraBankMovementReconciledBy")
  createdCarteraCollectionFollowUps     CarteraCollectionFollowUp[]   @relation("CarteraCollectionFollowUpCreatedBy")
  createdCarteraPaymentPromises         CarteraPaymentPromise[]       @relation("CarteraPaymentPromiseCreatedBy")
  carteraPayments                       CarteraPayment[]
  carteraReceiptApplications            CarteraReceiptApplication[]
  carteraReceipts                       CarteraReceipt[]
  importJobs                            ImportJob[]
  approvedInvoiceApprovalRequests       InvoiceApprovalRequest[]      @relation("InvoiceApprovalApprovedBy")
  requestedInvoiceApprovalRequests      InvoiceApprovalRequest[]      @relation("InvoiceApprovalRequestedBy")
  invoiceAttachments                    InvoiceAttachment[]
  invoiceDianProcessingJobs             InvoiceDianProcessingJob[]
  invoiceExternalIntakes                InvoiceExternalIntake[]
  approvedJournalEntryApprovalRequests  JournalEntryApprovalRequest[] @relation("JournalEntryApprovalApprovedBy")
  requestedJournalEntryApprovalRequests JournalEntryApprovalRequest[] @relation("JournalEntryApprovalRequestedBy")
  journalEntryAttachments               JournalEntryAttachment[]
  approvedPayrollApprovalRequests       PayrollApprovalRequest[]      @relation("PayrollApprovalApprovedBy")
  requestedPayrollApprovalRequests      PayrollApprovalRequest[]      @relation("PayrollApprovalRequestedBy")
  payrollAttachments                    PayrollAttachment[]
  payrollDianProcessingJobs             PayrollDianProcessingJob[]
  createdPosBankReconciliationBatches   PosBankReconciliationBatch[]  @relation("PosBankReconciliationBatchCreatedBy")
  posCashMovements                      PosCashMovement[]
  createdPosConfigDeployments           PosConfigDeployment[]         @relation("PosConfigDeploymentCreatedBy")
  createdPosIntegrationTraces           PosIntegrationTrace[]         @relation("PosIntegrationTraceCreatedBy")
  createdPosInventoryTransfers          PosInventoryTransfer[]        @relation("PosInventoryTransferCreatedBy")
  resolvedPosOperationalIncidents       PosOperationalIncident[]      @relation("PosOperationalIncidentResolvedBy")
  approvedPosPostSaleRequests           PosPostSaleRequest[]          @relation("PosPostSaleApprovedBy")
  createdPosPostSaleRequests            PosPostSaleRequest[]          @relation("PosPostSaleCreatedBy")
  approvedPosSessionCloses              PosSession[]                  @relation("PosSessionCloseApprovedBy")
  requestedPosSessionCloses             PosSession[]                  @relation("PosSessionCloseRequestedBy")
  reopenedPosSessions                   PosSession[]                  @relation("PosSessionReopenedBy")
  pos_sessions                          PosSession[]
  approvedPosGovernanceOverrides        PosSupervisorOverride[]       @relation("PosGovernanceApprovedBy")
  requestedPosGovernanceOverrides       PosSupervisorOverride[]       @relation("PosGovernanceRequestedBy")
  approvedPurchaseAdjustments           PurchaseAdjustment[]          @relation("PurchaseAdjustmentApprovedBy")
  createdPurchaseAdjustments            PurchaseAdjustment[]          @relation("PurchaseAdjustmentCreatedBy")
  createdPurchaseAdvances               PurchaseAdvance[]             @relation("PurchaseAdvanceCreatedBy")
  createdPurchaseBudgets                PurchaseBudget[]              @relation("PurchaseBudgetCreatedBy")
  createdPurchaseFrameworkAgreements    PurchaseFrameworkAgreement[]  @relation("PurchaseFrameworkAgreementCreatedBy")
  createdPurchaseInvoices               PurchaseInvoice[]             @relation("PurchaseInvoiceCreatedBy")
  createdPurchaseOrderReceipts          PurchaseOrderReceipt[]        @relation("PurchaseOrderReceiptCreatedBy")
  approvedPurchaseRequestApprovals      PurchaseRequestApproval[]     @relation("PurchaseRequestApprovalApprovedBy")
  createdPurchaseRequests               PurchaseRequest[]             @relation("PurchaseRequestCreatedBy")
  createdPurchaseSupplierQuotes         PurchaseSupplierQuote[]       @relation("PurchaseSupplierQuoteCreatedBy")
  approvedQuoteApprovalRequests         QuoteApprovalRequest[]        @relation("QuoteApprovalApprovedBy")
  requestedQuoteApprovalRequests        QuoteApprovalRequest[]        @relation("QuoteApprovalRequestedBy")
  quote_attachments                     QuoteAttachment[]
  quote_comments                        QuoteComment[]
  quoteFollowUps                        QuoteFollowUp[]
  quoteVersions                         QuoteVersion[]
  userBranches                          UserBranch[]
  roles                                 UserRole[]
  company                               Company?                      @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  displayName String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model RolePermission {
  id       String @id @default(uuid())
  roleId   String
  resource String
  action   String
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Category {
  id          String     @id @default(uuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  company     Company    @relation(fields: [companyId], references: [id])
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("categories")
}

model Product {
  id                              String                           @id @default(uuid())
  companyId                       String
  categoryId                      String?
  sku                             String
  name                            String
  description                     String?
  price                           Decimal                          @db.Decimal(12, 2)
  cost                            Decimal                          @default(0) @db.Decimal(12, 2)
  stock                           Int                              @default(0)
  minStock                        Int                              @default(0)
  unit                            String                           @default("UND")
  taxRate                         Decimal                          @default(19) @db.Decimal(5, 2)
  taxType                         TaxType                          @default(IVA)
  unspscCode                      String?
  status                          ProductStatus                    @default(ACTIVE)
  imageUrl                        String?
  barcode                         String?
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt
  deletedAt                       DateTime?
  branchId                        String?
  deliveryNoteItems               DeliveryNoteItem[]
  invoice_inventory_movements     InvoiceInventoryMovement[]
  invoiceItems                    InvoiceItem[]
  posComboItems                   PosComboItem[]
  posInventoryReservations        PosInventoryReservation[]
  posInventoryStocks              PosInventoryStock[]
  posInventoryTransferItems       PosInventoryTransferItem[]
  posPostSaleRequestItems         PosPostSaleRequestItem[]
  posPriceListItems               PosPriceListItem[]
  posPromotions                   PosPromotion[]
  posSaleItems                    PosSaleItem[]
  branch                          Branch?                          @relation(fields: [branchId], references: [id])
  category                        Category?                        @relation(fields: [categoryId], references: [id])
  company                         Company                          @relation(fields: [companyId], references: [id])
  purchaseFrameworkAgreementItems PurchaseFrameworkAgreementItem[]
  purchaseInventoryMovements      PurchaseInventoryMovement[]
  purchaseOrderItems              PurchaseOrderItem[]
  purchaseRequestItems            PurchaseRequestItem[]
  quoteItems                      QuoteItem[]
  quote_price_list_items          QuotePriceListItem[]
  quote_template_items            QuoteTemplateItem[]
  salesOrderItems                 SalesOrderItem[]

  @@index([companyId, branchId, sku])
  @@index([branchId])
  @@index([companyId])
  @@index([companyId, status])
  @@map("products")
}

model Customer {
  id                          String                       @id @default(uuid())
  companyId                   String
  documentType                DocumentType                 @default(NIT)
  documentNumber              String
  name                        String
  email                       String?
  phone                       String?
  address                     String?
  city                        String?
  department                  String?
  cityCode                    String?
  departmentCode              String?
  country                     String                       @default("CO")
  isActive                    Boolean                      @default(true)
  creditLimit                 Decimal?                     @db.Decimal(12, 2)
  creditDays                  Int?
  notes                       String?
  taxLevelCode                String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  deletedAt                   DateTime?
  loyaltyCode                 String?
  membershipTier              String?
  customerSegment             String?
  loyaltyPointsBalance        Int                          @default(0)
  loyaltyPointsEarned         Int                          @default(0)
  loyaltyPointsRedeemed       Int                          @default(0)
  lastPurchaseAt              DateTime?
  accountsPayable             AccountPayable[]
  carteraAdjustments          CarteraAdjustment[]
  carteraCollectionFollowUps  CarteraCollectionFollowUp[]
  carteraPaymentPromises      CarteraPaymentPromise[]
  carteraReceipts             CarteraReceipt[]
  company                     Company                      @relation(fields: [companyId], references: [id])
  deliveryNotes               DeliveryNote[]
  invoices                    Invoice[]
  journalEntryLines           JournalEntryLine[]
  posCouponRedemptions        PosCouponRedemption[]
  posCoupons                  PosCoupon[]
  posExternalOrders           PosExternalOrder[]
  posInventoryReservations    PosInventoryReservation[]
  posLoyaltyCampaigns         PosLoyaltyCampaign[]
  posLoyaltyTransactions      PosLoyaltyTransaction[]
  posPromotions               PosPromotion[]
  pos_sales                   PosSale[]
  purchaseAdjustments         PurchaseAdjustment[]
  purchaseAdvances            PurchaseAdvance[]
  purchaseFrameworkAgreements PurchaseFrameworkAgreement[]
  purchaseInvoices            PurchaseInvoice[]
  purchaseOrders              PurchaseOrder[]
  purchaseRequests            PurchaseRequest[]
  purchaseSupplierQuotes      PurchaseSupplierQuote[]
  quotes                      Quote[]
  salesOrders                 SalesOrder[]

  @@unique([companyId, documentType, documentNumber])
  @@index([companyId])
  @@map("customers")
}

model Invoice {
  id                          String                      @id @default(uuid())
  companyId                   String
  customerId                  String
  invoiceNumber               String
  prefix                      String                      @default("FV")
  type                        InvoiceType                 @default(VENTA)
  status                      InvoiceStatus               @default(DRAFT)
  issueDate                   DateTime
  dueDate                     DateTime?
  subtotal                    Decimal                     @db.Decimal(12, 2)
  taxAmount                   Decimal                     @db.Decimal(12, 2)
  discountAmount              Decimal                     @default(0) @db.Decimal(12, 2)
  total                       Decimal                     @db.Decimal(12, 2)
  notes                       String?
  dianCufe                    String?                     @unique
  dianQrCode                  String?
  dianStatus                  String?
  dianStatusCode              String?
  dianStatusMsg               String?
  dianErrors                  String?
  dianZipKey                  String?
  dianXmlBase64               String?
  dianSentAt                  DateTime?
  dianResponseAt              DateTime?
  dianAttempts                Int                         @default(0)
  xmlContent                  String?
  xmlSigned                   String?
  pdfUrl                      String?
  xmlUrl                      String?
  currency                    String                      @default("COP")
  exchangeRate                Decimal                     @default(1) @db.Decimal(12, 4)
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  deletedAt                   DateTime?
  dianCude                    String?                     @unique
  discrepancyReason           String?
  discrepancyReasonCode       String?
  originalInvoiceId           String?
  branchId                    String?
  sourceChannel               String?                     @default("DIRECT")
  sourceTerminalId            String?
  documentConfigId            String?
  resolutionNumber            String?
  resolutionLabel             String?
  numberingRangeFrom          Int?
  numberingRangeTo            Int?
  resolutionValidFrom         String?
  resolutionValidTo           String?
  fiscalRulesSnapshot         Json?
  salesOrderId                String?
  deliveryNoteId              String?
  sourceQuoteId               String?
  sourcePosSaleId             String?
  billingMode                 String?                     @default("FULL")
  appliedAdvanceAmount        Decimal                     @default(0) @db.Decimal(12, 2)
  inventoryStatus             String                      @default("PENDING")
  inventoryAppliedAt          DateTime?
  inventoryReversedAt         DateTime?
  deliveryStatus              String                      @default("PENDING")
  withholdingAmount           Decimal                     @default(0) @db.Decimal(12, 2)
  icaAmount                   Decimal                     @default(0) @db.Decimal(12, 2)
  fiscalValidationStatus      String                      @default("PENDING")
  fiscalValidationNotes       String?
  carteraAdjustments          CarteraAdjustment[]         @relation("CarteraAdjustmentInvoice")
  sourceCarteraAdjustments    CarteraAdjustment[]         @relation("CarteraAdjustmentSourceInvoice")
  carteraCollectionFollowUps  CarteraCollectionFollowUp[]
  carteraPaymentPromises      CarteraPaymentPromise[]
  payments                    CarteraPayment[]
  receiptApplications         CarteraReceiptApplication[]
  approvalRequests            InvoiceApprovalRequest[]
  attachments                 InvoiceAttachment[]
  dianJobs                    InvoiceDianProcessingJob[]
  externalIntakes             InvoiceExternalIntake[]
  invoice_inventory_movements InvoiceInventoryMovement[]
  items                       InvoiceItem[]
  branch                      Branch?                     @relation(fields: [branchId], references: [id])
  company                     Company                     @relation(fields: [companyId], references: [id])
  customer                    Customer                    @relation(fields: [customerId], references: [id])
  deliveryNote                DeliveryNote?               @relation(fields: [deliveryNoteId], references: [id])
  documentConfig              InvoiceDocumentConfig?      @relation(fields: [documentConfigId], references: [id])
  originalInvoice             Invoice?                    @relation("InvoiceNotes", fields: [originalInvoiceId], references: [id])
  creditDebitNotes            Invoice[]                   @relation("InvoiceNotes")
  salesOrder                  SalesOrder?                 @relation(fields: [salesOrderId], references: [id])
